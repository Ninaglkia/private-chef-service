---
import ChatWidget from '../components/ChatWidget.astro';

interface Props {
	title?: string;
	description?: string;
	bodyClass?: string;
}

const {
	title = 'Private Chef on Lake Como & Milan — Nino\'s Private Chef',
	description = 'Chef Nino, your personal private chef on Lake Como, in Milan and across Lombardy. Send a request and receive a bespoke menu and price, then a secure payment link — no fixed packages, no payment upfront. Breakfast, lunch, dinner or a buffet, crafted in your villa or home. Also available abroad on request.',
	bodyClass = 'bg-white text-gray-900'
} = Astro.props;

// Build an absolute canonical URL when a site is configured in astro.config.mjs.
const canonicalURL = Astro.site
	? new URL(Astro.url.pathname, Astro.site).href
	: Astro.url.href;
// Default Open Graph / Twitter share image.
// NOTE: /og-image.jpg is referenced but not yet present in /public — add a 1200x630 image there.
const ogImage = new URL('/og-image.jpg', Astro.site ?? Astro.url).href;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />

		<!-- PWA: installable as an app (one-tap access to the panel + persistent login) -->
		<link rel="manifest" href="/manifest.webmanifest" />
		<meta name="theme-color" content="#17130d" />
		<link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="Chef Nino" />
		<script is:inline>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js').catch(() => {});
				});
			}
		</script>
		<title>{title}</title>

		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={ogImage} />

		<!-- Local SEO: structured data for "private chef lake como / milan" queries -->
		<script type="application/ld+json" is:inline set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'FoodService',
			name: "Nino's Private Chef",
			url: 'https://ninos-privatechefs.com',
			image: 'https://ninos-privatechefs.com/images/chef.jpg',
			description: 'Premium private chef service: bespoke menus cooked in your villa or home on Lake Como, in Milan and across Lombardy.',
			email: 'info@ninos-privatechefs.com',
			priceRange: '€€€',
			areaServed: [
				{ '@type': 'Place', name: 'Lake Como' },
				{ '@type': 'City', name: 'Milan' },
				{ '@type': 'City', name: 'Como' },
				{ '@type': 'City', name: 'Bergamo' },
				{ '@type': 'AdministrativeArea', name: 'Lombardy' },
			],
			founder: { '@type': 'Person', name: 'Chef Nino', jobTitle: 'Private Chef' },
		})} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Cormorant+Garamond:wght@400;500;600;700&display=swap" rel="stylesheet" />

		<style>
			@keyframes fadeInUp {
				from {
					opacity: 0;
					transform: translateY(30px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@keyframes fadeIn {
				from {
					opacity: 0;
				}
				to {
					opacity: 1;
				}
			}

			.animate-fade-in-up {
				animation: fadeInUp 0.8s ease-out forwards;
			}

			.animate-fade-in {
				animation: fadeIn 1s ease-out forwards;
			}

			.animation-delay-200 {
				animation-delay: 0.2s;
				opacity: 0;
			}

			.animation-delay-400 {
				animation-delay: 0.4s;
				opacity: 0;
			}

			.animation-delay-600 {
				animation-delay: 0.6s;
				opacity: 0;
			}

			.animation-delay-800 {
				animation-delay: 0.8s;
				opacity: 0;
			}
		</style>
	</head>
	<body class={`antialiased ${bodyClass}`}>
		<slot />
		<ChatWidget />
		<script>
			// Restore scroll position to top on reload for mobile devices
			if (history.scrollRestoration) {
				history.scrollRestoration = 'manual';
			}
			
			window.addEventListener('load', () => {
				window.scrollTo(0, 0);
			});
		</script>
	</body>
</html>
