---
const { transparent = false } = Astro.props;
const pathname = Astro.url.pathname;
const loginUrl = `/login?returnTo=${encodeURIComponent(pathname)}`;
const signupUrl = `/signup?returnTo=${encodeURIComponent(pathname)}`;
---

<header id="main-header" class={`fixed w-full top-0 z-50 transition-all duration-300 ${transparent ? 'bg-transparent text-white' : 'bg-white/95 backdrop-blur-md shadow-soft border-b border-gray-100/50 text-gray-900'}`} data-transparent={transparent}>
  <nav class="container mx-auto px-4 sm:px-6 py-4">
    <div class="flex items-center justify-between">
      <a href="/" id="header-logo" class={`text-2xl font-semibold tracking-tight transition-colors ${transparent ? 'text-white' : 'text-gold-600'}`}>
        Private Chef
      </a>

      <div class="hidden md:flex items-center space-x-12">
        <a
          href="/#how-it-works"
          class={`text-sm font-medium transition-colors header-link ${transparent ? 'text-white/80 hover:text-white' : 'text-gray-600 hover:text-gray-900'}`}
        >
          How It Works
        </a>
        <a
          href="/menu"
          class={`text-sm font-medium transition-colors header-link ${transparent ? 'text-white/80 hover:text-white' : 'text-gray-600 hover:text-gray-900'}`}
        >
          La Carta
        </a>
        <a
          href="/richiesta"
          class={`text-sm font-medium transition-colors header-link ${transparent ? 'text-white/80 hover:text-white' : 'text-gray-600 hover:text-gray-900'}`}
        >
          Pricing
        </a>

        <a
          href="/#faq"
          class={`text-sm font-medium transition-colors header-link ${transparent ? 'text-white/80 hover:text-white' : 'text-gray-600 hover:text-gray-900'}`}
        >
          FAQ
        </a>
        <a
          href="/work-with-us"
          class={`text-sm font-medium transition-colors header-link ${transparent ? 'text-white/80 hover:text-white' : 'text-gray-600 hover:text-gray-900'}`}
        >
          Work with us
        </a>
        <div class="flex items-center gap-6 ml-auto">
          <div id="desktop-guest-actions" class="flex items-center gap-4">
            <a
              id="desktop-auth-link"
              href="/login"
              class={`text-sm font-semibold rounded-lg px-4 py-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-gray-900 focus-visible:ring-offset-transparent ${transparent ? 'text-white hover:text-gray-200' : 'text-gray-800 hover:text-black'}`}
            >
              Login
            </a>
            <a
              href="/signup"
              class="px-5 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-800 active:bg-black transition-colors duration-200 text-sm font-semibold shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-gray-900"
            >
              Sign Up
            </a>
            <a
              href="/richiesta"
              class="px-6 py-2.5 bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition-colors duration-300 text-sm font-semibold shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              Request a proposal
            </a>
          </div>
          <div id="desktop-user-actions" class="hidden items-center gap-4">
            <a
              href="/richiesta"
              class="px-5 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-800 active:bg-black transition-colors duration-200 text-sm font-semibold shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
              Request a proposal
            </a>
            
<!-- User Dropdown -->
            <div class="relative group">
              <button class="flex items-center gap-3 focus:outline-none">
                <div class="text-right hidden lg:block">
                  <p id="header-user-name" class="text-sm font-semibold text-gray-900 leading-none">User</p>
                  <p id="header-user-role" class="text-xs text-gray-500 mt-1">Customer</p>
                </div>
                <div id="header-avatar" class="h-10 w-10 rounded-full bg-gray-900 text-white flex items-center justify-center ring-2 ring-white shadow-md transition-colors duration-300">
                  <span class="font-semibold text-sm">U</span>
                </div>
              </button>

              <!-- Dropdown Menu -->
              <div class="absolute right-0 mt-2 w-64 bg-white rounded-xl shadow-xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-right z-50">
                <div class="p-4 border-b border-gray-50">
                  <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Account</p>
                  <p id="dropdown-email" class="text-sm font-medium text-gray-900 truncate">user@example.com</p>
                </div>
                
                <div class="p-2">
                  <a id="dashboard-link" href="/dashboard" class="flex items-center gap-3 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 rounded-lg transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                    Dashboard
                  </a>
                </div>

                <div class="p-2 border-t border-gray-50">
                  <button id="desktop-logout" class="w-full flex items-center gap-3 px-3 py-2 text-sm text-red-600 hover:bg-red-50 rounded-lg transition-colors text-left">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    Log out
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="flex items-center md:hidden gap-2">
        <div id="mobile-guest-actions" class="flex items-center gap-2">
          <a
            href="/richiesta"
            class="px-4 py-2.5 bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition-colors duration-300 text-sm font-semibold shadow-md"
          >
            Book Now
          </a>
        </div>
        <div id="mobile-user-actions" class="hidden items-center gap-2">
          <a
            id="mobile-dashboard-link"
            href="/dashboard"
            class="px-3 py-1.5 bg-gray-900 text-white rounded-lg hover:bg-gray-800 active:bg-black transition-colors duration-200 text-xs font-semibold shadow-md flex items-center gap-2"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="3.5" />
              <path d="M5 20.5c1.5-3 3.8-4.5 7-4.5s5.5 1.5 7 4.5" />
            </svg>
            <span>Dashboard</span>
          </a>
          <button
            id="mobile-logout"
            type="button"
            class="text-[11px] font-medium text-gray-600 hover:text-gray-900"
          >
            Log out
          </button>
        </div>
        <button
          class={`focus:outline-none transition-colors ${transparent ? 'text-white' : 'text-gray-900'}`}
          id="mobile-menu-button"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <div class="hidden md:hidden mt-2 pb-4 space-y-2 bg-white/95 backdrop-blur-md rounded-xl p-4 shadow-lg absolute left-4 right-4 top-full border border-gray-100" id="mobile-menu">
      <a href="/#how-it-works" class="block text-gray-700 hover:text-gray-900 text-sm font-medium py-3 px-2 rounded hover:bg-gray-50">How It Works</a>
      <a href="/menu" class="block text-gray-700 hover:text-gray-900 text-sm font-medium py-3 px-2 rounded hover:bg-gray-50">La Carta</a>
      <a href="/richiesta" class="block text-gray-700 hover:text-gray-900 text-sm font-medium py-3 px-2 rounded hover:bg-gray-50">Pricing</a>
      <a href="/#faq" class="block text-gray-700 hover:text-gray-900 text-sm font-medium py-3 px-2 rounded hover:bg-gray-50">FAQ</a>
      <a href="/work-with-us" class="block text-gray-700 hover:text-gray-900 text-sm font-medium py-3 px-2 rounded hover:bg-gray-50">Work with us</a>
      <a href="/richiesta" class="block text-center text-white bg-gray-900 hover:bg-gray-800 text-sm font-semibold py-3 px-2 rounded">Request a proposal</a>
      <a href={loginUrl} class="block text-gray-700 hover:text-gray-900 text-sm font-semibold py-3 px-2 rounded hover:bg-gray-50">Login</a>
      <a href={signupUrl} class="block text-center text-white bg-gray-900 hover:bg-gray-800 text-sm font-semibold py-3 px-2 rounded">Sign Up</a>
    </div>
  </nav>
</header>

<script>
  import { supabase, writeSessionCookies, clearSessionCookies } from '../lib/supabase';

  const header = document.getElementById('main-header');
  const logo = document.getElementById('header-logo');
  const links = document.querySelectorAll('.header-link');
  const menuBtn = document.getElementById('mobile-menu-button');
  const isTransparent = header?.dataset.transparent === 'true';

  // Auth Logic
  const desktopGuest = document.getElementById('desktop-guest-actions');
  const desktopUser = document.getElementById('desktop-user-actions');
  
  // Dropdown elements
  const headerUserName = document.getElementById('header-user-name');
  const headerUserRole = document.getElementById('header-user-role');
  const headerAvatar = document.getElementById('header-avatar');
  const dropdownEmail = document.getElementById('dropdown-email');
  const dashboardLink = document.getElementById('dashboard-link');
  const desktopLogout = document.getElementById('desktop-logout') as HTMLButtonElement | null;

  const mobileGuest = document.getElementById('mobile-guest-actions');
  const mobileUser = document.getElementById('mobile-user-actions');
  const mobileLogout = document.getElementById('mobile-logout') as HTMLButtonElement | null;
  const mobileDashboardLink = document.getElementById('mobile-dashboard-link') as HTMLAnchorElement | null;

  async function applyAuthState() {
    const { data: { user } } = await supabase.auth.getUser();

    if (user) {
      const meta = user.user_metadata || {};
      const name = (meta.full_name || meta.name || '') as string;
      const displayName = name || user.email?.split('@')[0] || 'User';

      if (desktopGuest && desktopUser) {
        desktopGuest.classList.add('hidden');
        desktopUser.classList.remove('hidden');
        // Make sure it's flex
        desktopUser.classList.add('flex');
      }

      const roleDisplay = 'Customer';

      // Update Desktop Header
      if (headerUserName) headerUserName.textContent = displayName;
      if (headerUserRole) headerUserRole.textContent = roleDisplay;
      if (dropdownEmail) dropdownEmail.textContent = user.email || '';
      
      if (mobileGuest && mobileUser) {
        mobileGuest.classList.add('hidden');
        mobileUser.classList.remove('hidden');
        mobileUser.classList.add('flex');
      }
    } else {
      if (desktopGuest && desktopUser) {
        desktopGuest.classList.remove('hidden');
        desktopUser.classList.add('hidden');
        desktopUser.classList.remove('flex');
      }
      if (mobileGuest && mobileUser) {
        mobileGuest.classList.remove('hidden');
        mobileUser.classList.add('hidden');
        mobileUser.classList.remove('flex');
      }
    }
  }

  async function handleLogout() {
    // Clear cookies
    document.cookie = 'sb-access-token=; path=/; max-age=0;';
    document.cookie = 'sb-refresh-token=; path=/; max-age=0;';
    await supabase.auth.signOut();
    window.location.href = '/';
  }

  desktopLogout?.addEventListener('click', (e) => {
    e.preventDefault();
    handleLogout();
  });

  mobileLogout?.addEventListener('click', (e) => {
    e.preventDefault();
    handleLogout();
  });

  // --- Proactively keep the server-readable auth cookies fresh on every page.
  // The SSR gate on /dashboard and /profile reads sb-access-token from the
  // cookie; if that cookie goes stale the page 302s to /login, which (seeing a
  // live client session) bounces back -> infinite redirect loop. Refreshing the
  // token on load — BEFORE the user navigates to a gated page — and writing the
  // result to the cookie prevents the cookie from ever being stale.
  // (Ongoing rotation/sign-out sync is handled centrally by the onAuthStateChange
  // listener in lib/supabase.ts; we deliberately do NOT duplicate it here.)
  async function syncAuthCookies() {
    try {
      let { data: { session } } = await supabase.auth.getSession();
      // Refresh if the access token is missing or expires within 2 min, so the
      // cookie handed to the server is always currently valid.
      const soon = Date.now() + 120000;
      if (session && (!session.expires_at || session.expires_at * 1000 < soon)) {
        const r = await supabase.auth.refreshSession();
        if (r.data.session) {
          session = r.data.session;
        } else {
          // Dead/rotated refresh token: the stored session can't be revived.
          // Sign out locally so the header flips to logged-out (instead of
          // showing a misleading "logged in" state while every gated page
          // bounces to /login), clear the cookie, and re-render the UI. The
          // user just logs in again and gets fresh, valid tokens.
          await supabase.auth.signOut({ scope: 'local' });
          clearSessionCookies();
          applyAuthState();
          return;
        }
      }
      if (session) writeSessionCookies(session);
    } catch { /* never break the header */ }
  }
  syncAuthCookies();

  applyAuthState();

  function updateHeader() {
    if (!header || !isTransparent) return;

    if (window.scrollY > 20) {
      header.classList.remove('bg-transparent', 'text-white');
      header.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-soft', 'border-b', 'border-gray-100/50', 'text-gray-900');
      
      logo?.classList.remove('text-white');
      logo?.classList.add('text-gold-600');
      
      menuBtn?.classList.remove('text-white');
      menuBtn?.classList.add('text-gray-900');

      links.forEach(link => {
        link.classList.remove('text-white/80', 'hover:text-white');
        link.classList.add('text-gray-600', 'hover:text-gray-900');
      });
    } else {
      header.classList.add('bg-transparent', 'text-white');
      header.classList.remove('bg-white/95', 'backdrop-blur-md', 'shadow-soft', 'border-b', 'border-gray-100/50', 'text-gray-900');
      
      logo?.classList.add('text-white');
      logo?.classList.remove('text-gold-600');
      
      menuBtn?.classList.add('text-white');
      menuBtn?.classList.remove('text-gray-900');

      links.forEach(link => {
        link.classList.add('text-white/80', 'hover:text-white');
        link.classList.remove('text-gray-600', 'hover:text-gray-900');
      });
    }
  }

  window.addEventListener('scroll', updateHeader);
  // Initial check
  updateHeader();

  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
  
  // Close menu when clicking outside
  document.addEventListener('click', (e) => {
    if (!header?.contains(e.target as Node)) {
      mobileMenu?.classList.add('hidden');
    }
  });
</script>
