---
// Shared profile form used by both onboarding (/complete-profile) and the
// account profile editor (/profile). Behaviour is mode-aware:
//   - mode="onboarding" -> on save, redirect to returnTo (or /dashboard)
//   - mode="edit"       -> on save, stay on the page and show a confirmation
import { EUROPEAN_COUNTRIES } from '../lib/european-data';

interface Props {
  mode?: 'onboarding' | 'edit';
  heading?: string;
  subheading?: string;
  submitLabel?: string;
  email?: string;
}

const {
  mode = 'edit',
  heading = mode === 'onboarding' ? 'Complete your profile' : 'My profile',
  subheading = mode === 'onboarding'
    ? 'We use this information to personalize your Private Chef experience.'
    : 'Update your contact details. We use these to plan and confirm your bookings.',
  submitLabel = mode === 'onboarding' ? 'Save and continue' : 'Save changes',
  email = '',
} = Astro.props;
---

<div class="bg-white shadow-xl rounded-2xl border border-gray-100 p-6 sm:p-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">{heading}</h1>
    <p class="mt-2 text-sm text-gray-500">{subheading}</p>
  </div>

  {email && (
    <div class="mb-5">
      <label class="block text-xs font-semibold text-gray-700 mb-1">Email</label>
      <input
        type="email"
        value={email}
        disabled
        class="block w-full rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-base text-gray-500 cursor-not-allowed"
      />
      <p class="mt-1 text-xs text-gray-400">Your email is tied to your account and can't be changed here.</p>
    </div>
  )}

  <form id="profile-form" class="space-y-5" data-mode={mode} novalidate>
    <div>
      <label class="block text-xs font-semibold text-gray-700 mb-1">Full name *</label>
      <input
        id="full_name"
        name="full_name"
        type="text"
        required
        class="block w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-base text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-black focus:border-black"
        placeholder="Name Surname"
      />
    </div>

    <div>
      <label for="phone_number_local" class="block text-xs font-semibold text-gray-700 mb-1">Phone *</label>
      <div class="flex gap-2">
        <div class="relative" id="country-selector">
          <input type="hidden" name="phone_country_code" id="phone_country_code" value="+39" />
          <button type="button" id="country-trigger" class="w-[120px] h-12 rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-black focus:border-black flex items-center justify-between gap-2 transition-all">
            <span class="flex items-center gap-1.5">
              <span id="selected-flag" class="text-lg">🇮🇹</span>
              <span id="selected-dial-code" class="font-medium">+39</span>
            </span>
            <svg class="w-4 h-4 text-gray-500 transition-transform duration-200" id="country-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div id="country-dropdown" class="hidden absolute top-full left-0 mt-2 w-full sm:w-72 max-h-72 overflow-y-auto bg-white border border-gray-200 rounded-lg shadow-xl z-50">
            <div class="p-2 sticky top-0 bg-white border-b border-gray-100 z-10">
              <input type="text" id="country-search" placeholder="Search country..." class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:border-black transition-colors" />
            </div>
            <ul class="py-1">
              {EUROPEAN_COUNTRIES.map((country) => (
                <li>
                  <button type="button" class="country-option w-full px-3 py-3 text-left hover:bg-gray-50 flex items-center gap-3 transition-colors border-b border-gray-50 last:border-0" data-code={country.dial_code} data-flag={country.flag} data-name={country.name.toLowerCase()}>
                    <span class="text-xl">{country.flag}</span>
                    <span class="flex-1 text-gray-900 text-sm font-medium">{country.name}</span>
                    <span class="text-gray-500 text-xs font-mono">{country.dial_code}</span>
                  </button>
                </li>
              ))}
            </ul>
          </div>
        </div>
        <input
          id="phone_number_local"
          name="phone_number_local"
          type="tel"
          inputmode="numeric"
          required
          class="flex-1 min-w-0 rounded-lg border border-gray-300 bg-white px-4 py-3 text-base text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-black focus:border-black"
          placeholder="333 1234567"
        />
      </div>
      <p id="phone-validation-msg" class="mt-1 text-xs text-red-500 hidden">Please enter a valid phone number (6-15 digits).</p>
    </div>

    <div>
      <label class="block text-xs font-semibold text-gray-700 mb-1">City *</label>
      <input
        id="city"
        name="city"
        type="text"
        required
        class="block w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-base text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-black focus:border-black"
        placeholder="Your city"
      />
    </div>

    <p id="profile-error" class="text-sm text-red-500 hidden"></p>
    <p id="profile-success" class="text-sm text-green-600 hidden">Profile saved.</p>

    <div class="pt-2 flex items-center justify-between gap-3">
      <button
        id="profile-submit"
        type="submit"
        class="inline-flex items-center justify-center gap-2 rounded-lg bg-black text-white px-5 py-3 text-sm font-semibold shadow-lg hover:bg-gray-900 active:scale-[0.99] transition-all disabled:opacity-60 disabled:cursor-not-allowed"
      >
        <span id="profile-submit-label">{submitLabel}</span>
        <span id="profile-spinner" class="hidden h-4 w-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
      </button>
    </div>
  </form>
</div>

<script>
  import { supabase } from '../lib/supabase';

  const form = document.getElementById('profile-form') as HTMLFormElement;
  const mode = (form?.dataset.mode === 'onboarding' ? 'onboarding' : 'edit') as 'onboarding' | 'edit';

  const fullNameInput = document.getElementById('full_name') as HTMLInputElement;
  const phoneInput = document.getElementById('phone_number_local') as HTMLInputElement;
  const cityInput = document.getElementById('city') as HTMLInputElement;
  const errorBox = document.getElementById('profile-error') as HTMLParagraphElement | null;
  const successBox = document.getElementById('profile-success') as HTMLParagraphElement | null;
  const submitBtn = document.getElementById('profile-submit') as HTMLButtonElement | null;
  const spinner = document.getElementById('profile-spinner') as HTMLSpanElement | null;

  // --- Phone country code selector ---
  const countrySelector = document.getElementById('country-selector');
  const countryTrigger = document.getElementById('country-trigger');
  const countryDropdown = document.getElementById('country-dropdown');
  const countrySearch = document.getElementById('country-search') as HTMLInputElement;
  const countryOptions = document.querySelectorAll('.country-option');
  const phoneCountryCode = document.getElementById('phone_country_code') as HTMLInputElement;
  const selectedFlag = document.getElementById('selected-flag');
  const selectedDialCode = document.getElementById('selected-dial-code');
  const countryArrow = document.getElementById('country-arrow');
  const phoneValidationMsg = document.getElementById('phone-validation-msg');

  function closeDropdown() {
    countryDropdown?.classList.add('hidden');
    countryArrow?.classList.remove('rotate-180');
    if (countrySearch) countrySearch.value = '';
    filterCountries('');
  }

  function filterCountries(query: string) {
    const lowerQuery = query.toLowerCase();
    countryOptions.forEach((option) => {
      const name = option.getAttribute('data-name') || '';
      const code = option.getAttribute('data-code') || '';
      (option.parentElement as HTMLElement).style.display =
        name.includes(lowerQuery) || code.includes(lowerQuery) ? 'block' : 'none';
    });
  }

  countryTrigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = countryDropdown?.classList.contains('hidden');
    if (isHidden) {
      countryDropdown?.classList.remove('hidden');
      countryArrow?.classList.add('rotate-180');
      countrySearch?.focus();
    } else {
      closeDropdown();
    }
  });

  document.addEventListener('click', (e) => {
    if (countrySelector && !countrySelector.contains(e.target as Node)) closeDropdown();
  });

  countrySearch?.addEventListener('input', (e) => filterCountries((e.target as HTMLInputElement).value));

  countryOptions.forEach((option) => {
    option.addEventListener('click', () => {
      const code = option.getAttribute('data-code');
      const flag = option.getAttribute('data-flag');
      if (code && flag) {
        phoneCountryCode.value = code;
        if (selectedFlag) selectedFlag.textContent = flag;
        if (selectedDialCode) selectedDialCode.textContent = code;
        countryOptions.forEach((opt) => opt.classList.remove('bg-gray-100'));
        option.classList.add('bg-gray-100');
        closeDropdown();
        phoneInput?.focus();
      }
    });
  });

  function setPhoneError(show: boolean) {
    if (show) {
      phoneInput.classList.add('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
      phoneInput.classList.remove('border-gray-300', 'focus:border-black', 'focus:ring-black');
      phoneValidationMsg?.classList.remove('hidden');
    } else {
      phoneInput.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
      phoneInput.classList.add('border-gray-300', 'focus:border-black', 'focus:ring-black');
      phoneValidationMsg?.classList.add('hidden');
    }
  }

  function isPhoneValid() {
    const digits = (phoneInput.value || '').replace(/[^0-9]/g, '');
    return digits.length >= 6 && digits.length <= 15;
  }

  phoneInput?.addEventListener('input', (e) => {
    const input = e.target as HTMLInputElement;
    input.value = input.value.replace(/[^0-9]/g, '');
    if (input.value.length === 0 || isPhoneValid()) setPhoneError(false);
  });
  phoneInput?.addEventListener('blur', () => {
    setPhoneError(phoneInput.value.length > 0 && !isPhoneValid());
  });

  const params = new URLSearchParams(window.location.search);
  const returnToParam = params.get('returnTo') || '/dashboard';

  async function init() {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) {
      const rt = encodeURIComponent(window.location.pathname + window.location.search);
      window.location.href = `/login?returnTo=${rt}`;
      return;
    }

    const { data: profile } = await supabase
      .from('profiles')
      .select('full_name, phone, city')
      .eq('id', user.id)
      .maybeSingle();

    if (profile) {
      if (profile.full_name) fullNameInput.value = profile.full_name;
      if (profile.city) cityInput.value = profile.city;
      if (profile.phone) prefillPhone(profile.phone);
    }
  }

  function prefillPhone(stored: string) {
    const value = String(stored).trim();
    // Stored format is "<dial_code> <local digits>", e.g. "+39 3281234567".
    const match = value.match(/^(\+\d{1,4})\s*(.*)$/);
    if (match) {
      const dial = match[1];
      const local = match[2].replace(/[^0-9]/g, '');
      const option = Array.from(countryOptions).find((o) => o.getAttribute('data-code') === dial);
      if (option) {
        phoneCountryCode.value = dial;
        if (selectedFlag) selectedFlag.textContent = option.getAttribute('data-flag') || '';
        if (selectedDialCode) selectedDialCode.textContent = dial;
      }
      phoneInput.value = local;
    } else {
      phoneInput.value = value.replace(/[^0-9]/g, '');
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errorBox) {
      errorBox.textContent = '';
      errorBox.classList.add('hidden');
    }
    successBox?.classList.add('hidden');

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    // Phone must be present and a valid local number (digits only, 6-15).
    if (!isPhoneValid()) {
      setPhoneError(true);
      phoneInput.focus();
      return;
    }

    if (submitBtn) submitBtn.disabled = true;
    if (spinner) spinner.classList.remove('hidden');

    try {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) throw new Error('Session expired, please log in again.');

      const fullName = fullNameInput.value.trim();
      const localPhone = phoneInput.value.replace(/[^0-9]/g, '');
      const dialCode = phoneCountryCode.value || '+39';
      const phone = `${dialCode} ${localPhone}`;
      const city = cityInput.value.trim();
      const completed = !!(fullName && localPhone && city);

      // NOTE: `role` is intentionally NOT written here. It is assigned
      // server-side by the handle_new_user trigger (default 'customer').
      // The client must never be able to set role:'admin' from the browser.
      // Note: email is NOT stored on profiles (it lives on auth.users / user.email).
      const { error } = await supabase
        .from('profiles')
        .upsert({
          id: user.id,
          full_name: fullName,
          phone,
          city,
          onboarding_completed: completed,
        });

      if (error) throw error;

      if (mode === 'onboarding') {
        window.location.href = returnToParam || '/dashboard';
        return;
      }

      // edit mode: stay on the page and confirm.
      successBox?.classList.remove('hidden');
      successBox?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    } catch (err: any) {
      if (errorBox) {
        errorBox.textContent = err.message || 'An error occurred';
        errorBox.classList.remove('hidden');
      }
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      if (spinner) spinner.classList.add('hidden');
    }
  });

  init();
</script>
