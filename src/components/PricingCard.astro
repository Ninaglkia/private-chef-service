---
import { formatPrice } from '../lib/pricing';

interface Props {
  /** Card title (e.g. "Single Day", "Abroad & Bespoke"). */
  name: string;
  /** Price in euro cents. Omit for quote-only cards (Custom / Abroad). */
  priceCents?: number;
  /** Shown instead of a price for quote-only cards (e.g. "By quote"). */
  priceLabel?: string;
  /** Small cadence line under the price (e.g. "per day", "per weekend", "per week"). */
  cadence?: string;
  /** Sub-line shown for quote-only cards under the price label. */
  cadenceLabel?: string;
  /** Short tagline shown under the title. */
  tagline: string;
  features: string[];
  highlighted?: boolean;
  buttonText?: string;
  buttonHref?: string;
  badge?: string;
}

const {
  name,
  priceCents,
  priceLabel,
  cadence,
  cadenceLabel = 'tailored to your needs',
  tagline,
  features,
  highlighted = false,
  buttonText = 'Book Now',
  buttonHref = '/booking',
  badge,
} = Astro.props;
---

<div
  class={`block relative bg-white rounded-3xl shadow-soft hover:shadow-soft-xl transition-all duration-500 overflow-hidden h-full flex flex-col border pricing-card ${highlighted ? 'border-gold-400 shadow-soft-lg' : 'border-gray-100 hover:border-gold-200'} group`}
>
  {badge && (
    <div class={`absolute top-0 left-0 right-0 text-center py-3 text-sm font-semibold tracking-wide shadow-soft ${highlighted ? 'bg-gradient-to-r from-gold-500 to-gold-600 text-white' : 'bg-gray-100 text-gray-700'}`}>
      {badge}
    </div>
  )}

  <div class={`p-6 sm:p-8 ${badge ? 'pt-16' : ''} flex flex-col flex-1`}>
    <div class="min-h-0 md:min-h-[6rem] mb-6 flex flex-col justify-start">
      <h3 class="text-2xl font-serif font-semibold text-gray-900 mb-2 leading-tight">{name}</h3>
      <p class="text-gray-600 text-sm">{tagline}</p>
    </div>

    <div class="min-h-0 md:min-h-[5.5rem] mb-8 flex flex-col justify-center">
      {priceCents !== undefined ? (
        <>
          <div class="text-4xl font-serif font-semibold text-gray-900 leading-tight">{formatPrice(priceCents)}</div>
          {cadence && <div class="text-gray-600 mt-1 text-sm">{cadence}</div>}
        </>
      ) : (
        <>
          <div class="text-3xl font-serif font-semibold text-gray-900 leading-tight">{priceLabel || 'Custom quote'}</div>
          <div class="text-gray-600 mt-1 text-sm">{cadenceLabel}</div>
        </>
      )}
    </div>

    <div class="flex-1 flex flex-col">
      <div class="mb-6 flex-1">
        <h4 class="font-semibold text-gray-900 mb-3 text-base">What's included</h4>
        <ul class="space-y-2">
          {features.map((feature) => (
            <li class="flex items-start text-gray-700 text-sm">
              <svg class="w-4 h-4 text-green-600 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
              {feature}
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-8">
        <a
          href={buttonHref}
          class={`block w-full py-3 px-4 text-center rounded-xl font-semibold transition-all duration-300 transform hover:scale-[1.02] shadow-md hover:shadow-lg ${
            highlighted
              ? 'bg-gold-500 text-white hover:bg-gold-600 shadow-gold/20'
              : 'bg-gray-900 text-white hover:bg-gray-800'
          }`}
        >
          {buttonText}
        </a>
        <p class="text-xs text-gray-500 text-center leading-relaxed mt-3">
          Subject to confirmation within 48 hours. Full refund if not confirmed.
        </p>
      </div>
    </div>
  </div>
</div>
