---
// Floating client chat widget (bottom-right), shown on every page via Layout.
// Logged-in clients get a real-time two-way thread with Chef Nino; guests get a
// prompt to log in plus a direct WhatsApp link.
const WHATSAPP_NUMBER = '393285515590'; // Chef Nino — also reachable on WhatsApp
---

<div id="chat-widget" class="fixed bottom-5 right-5 z-[60] font-sans">
  <!-- Launcher -->
  <button
    id="chat-launcher"
    aria-label="Open chat"
    class="flex items-center justify-center w-14 h-14 rounded-full bg-gradient-to-br from-gold-500 to-gold-700 text-white shadow-xl hover:scale-105 active:scale-95 transition-transform"
  >
    <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7A8.38 8.38 0 0 1 4 11.5a8.5 8.5 0 0 1 8.5-8.5 8.38 8.38 0 0 1 8.5 8.5Z" />
    </svg>
    <span id="chat-unread" class="hidden absolute -top-1 -right-1 min-w-[20px] h-5 px-1.5 rounded-full bg-red-500 text-white text-xs font-bold flex items-center justify-center"></span>
  </button>

  <!-- Panel -->
  <div
    id="chat-panel"
    class="hidden absolute bottom-16 right-0 w-[92vw] max-w-sm h-[70vh] max-h-[560px] bg-white rounded-2xl shadow-2xl border border-gray-200 flex flex-col overflow-hidden"
  >
    <div class="bg-[#17130d] text-white px-4 py-3 flex items-center gap-3">
      <span class="flex items-center justify-center w-9 h-9 rounded-full bg-gold-600 text-white font-serif italic">N</span>
      <div class="flex-1">
        <p class="text-sm font-semibold leading-tight">Chef Nino</p>
        <p class="text-[11px] text-gray-300 leading-tight">Usually replies within a few hours</p>
      </div>
      <button id="chat-close" aria-label="Close" class="text-gray-300 hover:text-white text-xl leading-none">×</button>
    </div>

    <!-- WhatsApp is the primary channel: Nino replies from his phone. -->
    <div class="px-3 pt-3">
      <a
        id="chat-wa-primary"
        href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent("Hi Chef Nino! I'd like some information / to make a booking.")}`}
        target="_blank"
        rel="noopener"
        class="flex items-center justify-center gap-2 rounded-xl bg-[#25D366] text-white py-3 text-sm font-semibold shadow hover:bg-[#1ebe5b] active:scale-[0.99] transition-all"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zM6.597 20.13c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.512 5.26l-.999 3.648 3.875-.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
        Message us on WhatsApp
      </a>
      <p class="text-center text-[11px] text-gray-400 my-2">or write to us below</p>
    </div>

    <div id="chat-messages" class="flex-1 overflow-y-auto px-3 py-2 space-y-2 bg-[#faf7f1]"></div>

    <!-- Guest state: the in-app chat needs login; WhatsApp (above) works for everyone. -->
    <div id="chat-guest" class="hidden p-4 text-center border-t border-gray-100">
      <p class="text-sm text-gray-600 mb-3">To chat here on the site, sign in to your account. To talk to Chef Nino right away, use WhatsApp above.</p>
      <a href="/login?returnTo=%2F" class="block w-full rounded-lg bg-black text-white py-2.5 text-sm font-semibold">Sign in</a>
    </div>

    <!-- Composer -->
    <form id="chat-form" class="hidden border-t border-gray-100 p-2.5 flex items-end gap-2">
      <textarea
        id="chat-input"
        rows="1"
        placeholder="Type a message…"
        class="flex-1 resize-none rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500 max-h-28"
      ></textarea>
      <button type="submit" class="shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-gold-500 to-gold-700 text-white flex items-center justify-center disabled:opacity-50">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z" /><path d="M22 2 11 13" /></svg>
      </button>
    </form>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase';

  const launcher = document.getElementById('chat-launcher');
  const panel = document.getElementById('chat-panel');
  const closeBtn = document.getElementById('chat-close');
  const list = document.getElementById('chat-messages');
  const form = document.getElementById('chat-form') as HTMLFormElement | null;
  const input = document.getElementById('chat-input') as HTMLTextAreaElement | null;
  const guestBox = document.getElementById('chat-guest');
  const unreadBadge = document.getElementById('chat-unread');

  const WA_NUMBER = '393285515590';
  let clientId: string | null = null;
  let loaded = false;
  let open = false;

  function esc(s: string) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function bubble(m: { sender: string; body: string; created_at?: string }) {
    const mine = m.sender === 'client';
    const time = m.created_at
      ? new Date(m.created_at).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' })
      : '';
    return `
      <div class="flex ${mine ? 'justify-end' : 'justify-start'}">
        <div class="${mine ? 'bg-gold-600 text-white' : 'bg-white text-gray-800 border border-gray-200'} max-w-[80%] rounded-2xl px-3 py-2 text-sm shadow-sm">
          <div>${esc(m.body)}</div>
          <div class="${mine ? 'text-gold-100' : 'text-gray-400'} text-[10px] mt-1 text-right">${time}</div>
        </div>
      </div>`;
  }

  function scrollDown() {
    if (list) list.scrollTop = list.scrollHeight;
  }

  function append(m: any) {
    if (!list) return;
    list.insertAdjacentHTML('beforeend', bubble(m));
    scrollDown();
  }

  async function loadThread() {
    if (!clientId || !list) return;
    const { data } = await supabase
      .from('messages')
      .select('sender, body, created_at')
      .eq('client_id', clientId)
      .order('created_at', { ascending: true });
    list.innerHTML = '';
    if (!data || data.length === 0) {
      list.innerHTML = `<div class="text-center text-gray-400 text-sm py-6">Hi there! 👋 Message Chef Nino with any questions about your booking or the menu.</div>`;
    } else {
      for (const m of data) append(m);
    }
    // Mark owner messages as read by the client.
    await supabase.from('messages').update({ read_by_client: true })
      .eq('client_id', clientId).eq('sender', 'owner').eq('read_by_client', false);
    if (unreadBadge) unreadBadge.classList.add('hidden');
  }

  function subscribe() {
    if (!clientId) return;
    supabase
      .channel(`chat:${clientId}`)
      .on(
        'postgres_changes',
        { event: 'INSERT', schema: 'public', table: 'messages', filter: `client_id=eq.${clientId}` },
        (payload: any) => {
          const m = payload.new;
          append(m);
          if (m.sender === 'owner' && !open && unreadBadge) {
            unreadBadge.textContent = '1';
            unreadBadge.classList.remove('hidden');
          }
        }
      )
      .subscribe();
  }

  function personalizeWhatsApp(name?: string | null) {
    const waBtn = document.getElementById('chat-wa-primary') as HTMLAnchorElement | null;
    if (!waBtn) return;
    const n = (name || '').trim();
    const text = n ? `Hi Chef Nino! This is ${n}.` : "Hi Chef Nino! I'd like some information / to make a booking.";
    waBtn.href = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(text)}`;
  }

  async function init() {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) {
      guestBox?.classList.remove('hidden');
      return;
    }
    clientId = user.id;
    const meta: any = user.user_metadata || {};
    personalizeWhatsApp(meta.full_name || meta.name || '');
    form?.classList.remove('hidden');
    await loadThread();
    subscribe();
    loaded = true;
  }

  launcher?.addEventListener('click', async () => {
    open = !open;
    panel?.classList.toggle('hidden', !open);
    if (open && !loaded) await init();
    if (open) {
      scrollDown();
      if (unreadBadge) unreadBadge.classList.add('hidden');
    }
  });
  closeBtn?.addEventListener('click', () => {
    open = false;
    panel?.classList.add('hidden');
  });

  input?.addEventListener('input', () => {
    if (!input) return;
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 112) + 'px';
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!clientId || !input) return;
    const body = input.value.trim();
    if (!body) return;
    input.value = '';
    input.style.height = 'auto';
    const { error } = await supabase.from('messages').insert({ client_id: clientId, sender: 'client', body });
    if (error) {
      append({ sender: 'client', body, created_at: new Date().toISOString() });
      alert('Message not sent, please try again.');
    }
    // On success the realtime INSERT handler appends it.
  });
</script>
