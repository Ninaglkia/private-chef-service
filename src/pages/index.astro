---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import PricingCard from '../components/PricingCard.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import ChefCarousel from '../components/ChefCarousel.astro';
import { PRODUCT_LIST, CUSTOM_PLAN, MAX_GUESTS } from '../lib/pricing';

const cadenceFor = (days: number) =>
  days >= 7 ? 'per week' : days === 2 ? 'per weekend' : 'per day';
---

<Layout>
  <Header transparent={true} />

  <main>
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
      <HeroCarousel />
      <div class="container mx-auto px-6 text-center relative z-20">
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-semibold text-white mb-6 leading-tight">
          Premium Private Chef Service
        </h1>
        <p class="text-lg md:text-xl text-gray-100 mb-12 max-w-2xl mx-auto leading-relaxed">
          Book Chef Nino for a day, a weekend or a full week — for up to 15 guests at the same price. Breakfast, lunch and dinner, or whatever you prefer, prepared fresh in your home.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/richiesta" size="lg">
            Book Now
          </Button>
          <Button href="#how-it-works" variant="outline" size="lg">
            Learn More
          </Button>
        </div>

        <div class="mt-12 sm:mt-20 grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-8 max-w-4xl mx-auto">
          <div class="text-center bg-white/5 backdrop-blur-md rounded-xl p-6 sm:p-8 border border-white/10">
            <div class="text-3xl sm:text-4xl font-semibold text-white mb-2">Flexible</div>
            <div class="text-gray-300 text-base">Day, weekend or week</div>
          </div>
          <div class="text-center bg-white/5 backdrop-blur-md rounded-xl p-6 sm:p-8 border border-white/10">
            <div class="text-3xl sm:text-4xl font-semibold text-white mb-2">Up to 15</div>
            <div class="text-gray-300 text-base">Guests, same price</div>
          </div>
          <div class="text-center bg-white/5 backdrop-blur-md rounded-xl p-6 sm:p-8 border border-white/10">
            <div class="text-3xl sm:text-4xl font-semibold text-white mb-2">100%</div>
            <div class="text-gray-300 text-base">Premium Quality</div>
          </div>
        </div>
      </div>
    </section>

    <section id="how-it-works" class="py-16 md:py-32 bg-white">
      <div class="container mx-auto px-4 md:px-6">
        <div class="text-center mb-12 md:mb-20">
          <h2 class="text-3xl md:text-5xl font-semibold text-gray-900 mb-4 md:mb-6">
            How It Works
          </h2>
          <p class="text-base md:text-lg text-gray-600 max-w-2xl mx-auto">
            Simple, straightforward process to get started with your private chef service
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-7xl mx-auto">
          <div class="text-center">
            <div class="w-16 h-16 bg-gray-900 text-white rounded-full flex items-center justify-center text-2xl font-semibold mx-auto mb-6">
              1
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Choose a Package</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Pick a single day, a weekend or a full week — for up to 15 guests at one flat price
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-gray-900 text-white rounded-full flex items-center justify-center text-2xl font-semibold mx-auto mb-6">
              2
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Book & Pay</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Complete your booking with secure online payment
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-gray-900 text-white rounded-full flex items-center justify-center text-2xl font-semibold mx-auto mb-6">
              3
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Plan Your Menu</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Chef Nino creates a personalised menu around your tastes and dietary needs
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 bg-gray-900 text-white rounded-full flex items-center justify-center text-2xl font-semibold mx-auto mb-6">
              4
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Enjoy</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Relax while Chef Nino prepares fresh meals in your own kitchen
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20 bg-white border-t border-gray-100">
      <div class="container mx-auto px-4 md:px-6">
        <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
          <div class="w-full md:w-1/2 relative min-h-0 md:min-h-[400px] overflow-hidden">
             <div class="absolute inset-0 bg-gold-100 rounded-2xl transform rotate-3 scale-105 opacity-50"></div>
             <div class="relative z-10 w-full h-full">
               <ChefCarousel />
             </div>
          </div>
          <div class="w-full md:w-1/2">
            <h2 class="text-3xl md:text-5xl font-semibold mb-4 md:mb-6 text-gray-900 leading-tight">
              Meet Chef Nino
              <span class="block text-gold-600 text-xl md:text-2xl mt-2 md:mt-3 font-medium">Founder & Executive Chef</span>
            </h2>
            <p class="text-gray-600 leading-relaxed mb-4 md:mb-6 text-base md:text-lg italic">
              "Cooking is not just about ingredients, it's about creating memories. As a private chef, my mission is to bring the sophistication of fine dining directly to your family table."
            </p>
            <p class="text-gray-600 leading-relaxed mb-6 md:mb-8 text-base md:text-lg">
              With over 15 years of culinary excellence in top-tier kitchens, I personally handle every aspect of the service to ensure your experience is nothing short of perfection. From sourcing the finest ingredients to curating seasonal menus, my personal touch is in every detail.
            </p>
            
            <div class="grid grid-cols-2 gap-4 md:gap-6 mt-6 md:mt-8">
               <div class="border-l-4 border-gold-500 pl-4 md:pl-6">
                  <p class="text-2xl md:text-3xl font-bold text-gray-900">15+</p>
                  <p class="text-xs md:text-sm text-gray-500 uppercase tracking-wide mt-1">Years Experience</p>
               </div>
               <div class="border-l-4 border-gold-500 pl-4 md:pl-6">
                  <p class="text-2xl md:text-3xl font-bold text-gray-900">100%</p>
                  <p class="text-xs md:text-sm text-gray-500 uppercase tracking-wide mt-1">Satisfaction</p>
               </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-32 bg-gray-50">
      <div class="container mx-auto px-4 md:px-6">
        <div class="text-center mb-12 md:mb-20">
          <h2 class="text-3xl md:text-5xl font-semibold text-gray-900 mb-4 md:mb-6">
            What's Included
          </h2>
          <p class="text-base md:text-lg text-gray-600 max-w-2xl mx-auto">
            Every plan includes premium service and attention to detail
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 max-w-7xl mx-auto">
          <div class="bg-white p-6 md:p-10 rounded-2xl shadow-soft hover:shadow-soft-lg transition-all duration-300 border border-gray-100">
            <div class="w-12 h-12 md:w-14 md:h-14 bg-gray-900 rounded-lg flex items-center justify-center mb-4 md:mb-6">
              <svg class="w-6 h-6 md:w-7 md:h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-2 md:mb-3">Professional Chef</h3>
            <p class="text-gray-600 text-sm">
              Chef Nino — experienced and certified, with expertise across many cuisines
            </p>
          </div>

          <div class="bg-white p-6 md:p-10 rounded-2xl shadow-soft hover:shadow-soft-lg transition-all duration-300 border border-gray-100">
            <div class="w-12 h-12 md:w-14 md:h-14 bg-gray-900 rounded-lg flex items-center justify-center mb-4 md:mb-6">
              <svg class="w-6 h-6 md:w-7 md:h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
            </div>
            <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-2 md:mb-3">Menu Planning</h3>
            <p class="text-gray-600 text-sm">
              Customized menus tailored to your dietary needs and preferences
            </p>
          </div>

          <div class="bg-white p-6 md:p-10 rounded-2xl shadow-soft hover:shadow-soft-lg transition-all duration-300 border border-gray-100">
            <div class="w-12 h-12 md:w-14 md:h-14 bg-gray-900 rounded-lg flex items-center justify-center mb-4 md:mb-6">
              <svg class="w-6 h-6 md:w-7 md:h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-2 md:mb-3">Groceries</h3>
            <p class="text-gray-600 text-sm">
              Chef Nino shops for the finest ingredients — groceries are billed separately, at cost.
            </p>
          </div>

          <div class="bg-white p-6 md:p-10 rounded-2xl shadow-soft hover:shadow-soft-lg transition-all duration-300 border border-gray-100">
            <div class="w-12 h-12 md:w-14 md:h-14 bg-gray-900 rounded-lg flex items-center justify-center mb-4 md:mb-6">
              <svg class="w-6 h-6 md:w-7 md:h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-2 md:mb-3">Daily Fresh Meals</h3>
            <p class="text-gray-600 text-sm">
              Breakfast, lunch, and dinner prepared fresh daily in your home
            </p>
          </div>

          <div class="bg-white p-6 md:p-10 rounded-2xl shadow-soft hover:shadow-soft-lg transition-all duration-300 border border-gray-100">
            <div class="w-12 h-12 md:w-14 md:h-14 bg-gray-900 rounded-lg flex items-center justify-center mb-4 md:mb-6">
              <svg class="w-6 h-6 md:w-7 md:h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-2 md:mb-3">Kitchen Management</h3>
            <p class="text-gray-600 text-sm">
              Complete kitchen cleanup and organization after each service
            </p>
          </div>

          <div class="bg-white p-6 md:p-10 rounded-2xl shadow-soft hover:shadow-soft-lg transition-all duration-300 border border-gray-100">
            <div class="w-12 h-12 md:w-14 md:h-14 bg-gray-900 rounded-lg flex items-center justify-center mb-4 md:mb-6">
              <svg class="w-6 h-6 md:w-7 md:h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-lg md:text-xl font-semibold text-gray-900 mb-2 md:mb-3">Premium Ingredients</h3>
            <p class="text-gray-600 text-sm">
              Only the finest, freshest ingredients from trusted suppliers
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="pricing" class="py-16 md:py-32 bg-white">
      <div class="container mx-auto px-4 md:px-6">
        <div class="max-w-2xl mx-auto text-center">
          <div class="flex items-center justify-center gap-3 mb-5">
            <span class="h-px w-8 bg-gold-500/60"></span>
            <span class="text-[11px] uppercase tracking-[0.25em] text-gold-600">Bespoke</span>
            <span class="h-px w-8 bg-gold-500/60"></span>
          </div>
          <h2 class="text-3xl md:text-5xl font-semibold text-gray-900 mb-5">Every event is unique</h2>
          <p class="text-base md:text-lg text-gray-600 leading-relaxed">
            No off-the-shelf packages. Tell us about the evening you have in mind — the occasion, your guests, the atmosphere —
            and Chef Nino will design the menu and send you a bespoke proposal with the price. Groceries are billed
            separately, at cost. Service across Lombardy and, on request, abroad.
          </p>

          <a href="/richiesta"
            class="mt-9 inline-flex items-center justify-center gap-2 rounded-full bg-gray-900 text-white px-8 py-4 text-base font-semibold shadow-lg hover:bg-black active:scale-[0.99] transition-all">
            <span class="text-gold-400">✦</span>
            Design your evening
          </a>
          <p class="mt-4 text-sm text-gray-400">No payment now · reply within 24 hours</p>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-32 bg-gray-900 text-white relative overflow-hidden">
      <div class="container mx-auto px-4 md:px-6 relative z-10">
        <div class="max-w-5xl mx-auto">
          <div class="text-center mb-12 md:mb-20">
            <h2 class="text-3xl md:text-5xl font-semibold mb-4 md:mb-6">
              Why Choose Us
            </h2>
            <p class="text-base md:text-lg text-gray-300">
              Professional service with attention to detail and quality
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10">
            <div class="flex items-start p-6 md:p-8 bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 hover:bg-white/10 transition-all duration-300">
              <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-gray-800 rounded-lg flex items-center justify-center mr-4 md:mr-6">
                <svg class="w-5 h-5 md:w-6 md:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold mb-2">Vetted Professionals</h3>
                <p class="text-gray-300 text-sm">
                  Chef Nino is a certified professional with years of experience in top-tier kitchens
                </p>
              </div>
            </div>

            <div class="flex items-start p-6 md:p-8 bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 hover:bg-white/10 transition-all duration-300">
              <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-gray-800 rounded-lg flex items-center justify-center mr-4 md:mr-6">
                <svg class="w-5 h-5 md:w-6 md:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold mb-2">Safe & Secure</h3>
                <p class="text-gray-300 text-sm">
                  Background-checked staff, secure payments, and comprehensive insurance coverage
                </p>
              </div>
            </div>

            <div class="flex items-start p-6 md:p-8 bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 hover:bg-white/10 transition-all duration-300">
              <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-gray-800 rounded-lg flex items-center justify-center mr-4 md:mr-6">
                <svg class="w-5 h-5 md:w-6 md:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold mb-2">Personalized Service</h3>
                <p class="text-gray-300 text-sm">
                  Menus adapted to your tastes, dietary restrictions, and family preferences
                </p>
              </div>
            </div>

            <div class="flex items-start p-6 md:p-8 bg-white/5 backdrop-blur-sm rounded-2xl border border-white/10 hover:bg-white/10 transition-all duration-300">
              <div class="flex-shrink-0 w-10 h-10 md:w-12 md:h-12 bg-gray-800 rounded-lg flex items-center justify-center mr-4 md:mr-6">
                <svg class="w-5 h-5 md:w-6 md:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold mb-2">Hassle-Free</h3>
                <p class="text-gray-300 text-sm">
                  No shopping, no cooking, no cleanup. Just enjoy exceptional meals every day
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="faq" class="py-16 md:py-32 bg-white">
      <div class="container mx-auto px-4 md:px-6">
        <div class="text-center mb-12 md:mb-20">
          <h2 class="text-3xl md:text-5xl font-semibold text-gray-900 mb-4 md:mb-6">
            Frequently Asked Questions
          </h2>
        </div>

        <div class="max-w-4xl mx-auto space-y-4">
          <details class="group bg-gray-50 rounded-xl p-6 cursor-pointer hover:shadow-soft transition-shadow border border-gray-200">
            <summary class="flex justify-between items-center gap-3 pr-2 font-semibold text-base sm:text-lg text-gray-900 list-none">
              <span>How far in advance should I book?</span>
              <svg class="w-6 h-6 text-gold-600 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-gray-600 text-sm">
              We recommend booking at least 2 weeks ahead to secure your dates, as Chef Nino takes a limited number of bookings. Last-minute requests can often be accommodated depending on availability — and if your dates can't be served, you receive a full refund.
            </p>
          </details>

          <details class="group bg-gray-50 rounded-xl p-6 cursor-pointer hover:shadow-soft transition-shadow border border-gray-200">
            <summary class="flex justify-between items-center gap-3 pr-2 font-semibold text-base sm:text-lg text-gray-900 list-none">
              <span>What if I have dietary restrictions?</span>
              <svg class="w-6 h-6 text-gold-600 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-gray-600 text-sm">
              Chef Nino is experienced in accommodating all dietary needs including vegan, vegetarian, gluten-free, kosher, halal, and specific allergies. Simply specify your requirements during booking.
            </p>
          </details>

          <details class="group bg-gray-50 rounded-xl p-6 cursor-pointer hover:shadow-soft transition-shadow border border-gray-200">
            <summary class="flex justify-between items-center gap-3 pr-2 font-semibold text-base sm:text-lg text-gray-900 list-none">
              <span>Do I need to provide any kitchen equipment?</span>
              <svg class="w-6 h-6 text-gold-600 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-gray-600 text-sm">
              Chef Nino works with your existing kitchen equipment. We recommend having basic cooking utensils, pots, pans, and appliances. If anything specific is needed, Chef Nino will discuss it with you before service begins.
            </p>
          </details>

          <details class="group bg-gray-50 rounded-xl p-6 cursor-pointer hover:shadow-soft transition-shadow border border-gray-200">
            <summary class="flex justify-between items-center gap-3 pr-2 font-semibold text-base sm:text-lg text-gray-900 list-none">
              <span>What time will the chef arrive?</span>
              <svg class="w-6 h-6 text-gold-600 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-gray-600 text-sm">
              Service times are customised to your schedule. Chef Nino will coordinate with you to determine the best times for meal preparation, based on when you prefer to eat — breakfast, lunch, dinner, or whatever suits you.
            </p>
          </details>

          <details class="group bg-gray-50 rounded-xl p-6 cursor-pointer hover:shadow-soft transition-shadow border border-gray-200">
            <summary class="flex justify-between items-center gap-3 pr-2 font-semibold text-base sm:text-lg text-gray-900 list-none">
              <span>Can I cancel or reschedule?</span>
              <svg class="w-6 h-6 text-gold-600 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-gray-600 text-sm">
