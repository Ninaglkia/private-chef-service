---
import Layout from '../layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';
import { isOwnerEmail } from '../lib/admin';

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const supabase = createClient(supabaseUrl, supabaseAnonKey, {
  auth: {
    persistSession: false,
    autoRefreshToken: false,
  }
});

// Session is resolved (and refreshed) once in middleware → Astro.locals.user.
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect(`/login?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}

// Onboarding gate: a complete profile (name, phone, city) is required to continue.
// Read via the service-role key (server-only) so RLS / auth-context never blocks
// this read and cause a redirect loop with /complete-profile.
const supabaseAdmin = createClient(supabaseUrl, import.meta.env.SUPABASE_SERVICE_ROLE_KEY, {
  auth: { persistSession: false, autoRefreshToken: false },
});
const { data: onboardingProfile, error: profileError } = await supabaseAdmin
  .from('profiles')
  .select('full_name, phone, city')
  .eq('id', user.id)
  .maybeSingle();
// Fail OPEN on query error to avoid redirect loops; only gate when we can read the profile.
if (!profileError) {
  const incomplete = !onboardingProfile || !onboardingProfile.full_name || !onboardingProfile.phone || !onboardingProfile.city;
  if (incomplete) {
    return Astro.redirect('/complete-profile?returnTo=' + encodeURIComponent(Astro.url.pathname));
  }
}

// Owner override — email allowlist centralised in lib/admin.ts.
const isOwner = isOwnerEmail(user.email);

// Optional: Redirect admin/owner to control panel if they land here? 
// The client-side code does this. We can do it here too for faster redirect.
const { data: profile } = await supabase
  .from('profiles')
  .select('role')
  .eq('id', user.id)
  .single();

if ((profile?.role === 'admin' || isOwner)) {
   return Astro.redirect('/admin/control-panel');
}
---

<Layout title="Dashboard - Private Chef Service">
  <div class="max-w-7xl mx-auto py-8 sm:py-12 px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <header class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-4">
        <a href="/" class="inline-flex items-center gap-3 group">
          <span class="inline-flex h-9 w-9 rounded-full bg-black text-white items-center justify-center shadow-md group-hover:shadow-lg group-hover:scale-[1.03] transition-transform transition-shadow">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 11c0-3.5 2.7-6 7-6s7 2.5 7 6" />
              <path d="M7 11h10" />
              <path d="M8 15h8" />
              <path d="M9 19h6" />
            </svg>
          </span>
          <span class="text-xl sm:text-2xl font-semibold tracking-tight text-gray-900 group-hover:text-black">
            Private Chef
          </span>
        </a>
        <div class="hidden sm:flex flex-col">
          <span class="text-xs font-medium uppercase tracking-wide text-gray-400">Client Area</span>
          <span class="text-sm text-gray-600" id="user-email">{user.email}</span>
        </div>
      </div>
      <div class="flex items-center justify-between sm:justify-end gap-4">
        <div class="sm:hidden flex flex-col text-right min-w-0">
          <span class="text-sm font-semibold text-gray-900">Dashboard</span>
          <span class="text-xs text-gray-500 max-w-[160px] truncate" id="user-email-mobile">{user.email}</span>
        </div>
        <button id="logout-btn" class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 active:bg-gray-100 transition-colors">
          Log out
        </button>
      </div>
    </header>

    <!-- Content -->
    <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-6">
      <div class="px-4 py-5 sm:px-6">
        <h3 class="text-lg leading-6 font-medium text-gray-900">Your bookings</h3>
        <p class="mt-1 max-w-2xl text-sm text-gray-500">Pay, check the details and get in touch with Chef Nino.</p>
      </div>
      <div class="border-t border-gray-200 px-4 py-5 sm:p-6" id="booking-section">
        <p class="text-gray-500 text-sm">Loading bookings…</p>
      </div>
    </div>

    <!-- WhatsApp contact -->
    <div class="bg-white shadow sm:rounded-lg p-5 sm:p-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h3 class="text-base font-semibold text-gray-900">Talk to Chef Nino</h3>
        <p class="mt-1 text-sm text-gray-500">Questions about the menu, allergies, timings? Message me directly on WhatsApp.</p>
      </div>
      <a href="https://wa.me/393285515590?text=Hi%20Chef%20Nino%2C%20I%20have%20a%20question." target="_blank" rel="noopener"
         class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-lg text-sm font-semibold text-white bg-[#25D366] hover:bg-[#1ebe5a] active:bg-[#1aa550] shadow-sm transition-colors whitespace-nowrap">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.748-.748zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
        WhatsApp
      </a>
    </div>

  </div>
</Layout>

<script define:vars={{ userEmail: user.email }}>
  import { supabase } from '../lib/supabase';
  import { PRODUCTS, formatPrice } from '../lib/pricing';

  const bookingSection = document.getElementById('booking-section');
  const logoutBtn = document.getElementById('logout-btn');

  // Chef Nino's WhatsApp (same number as ORGANIZER_PHONE), no '+' for wa.me.
  const WA_NUMBER = '393285515590';
  const waLink = (text) => `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(text)}`;

  // Status labels (matches DB: pending/confirmed/completed/cancelled/refunded).
  const STATUS_LABELS = {
    pending: 'Awaiting payment',
    confirmed: 'Confirmed',
    completed: 'Completed',
    cancelled: 'Cancelled',
    refunded: 'Refunded',
  };

  const STATUS_STYLES = {
    pending: 'bg-amber-100 text-amber-800',
    confirmed: 'bg-green-100 text-green-800',
    completed: 'bg-blue-100 text-blue-800',
    cancelled: 'bg-gray-100 text-gray-800',
    refunded: 'bg-purple-100 text-purple-800',
  };

  function escapeHtml(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function formatDate(value) {
    if (!value) return null;
    const d = new Date(value);
    if (isNaN(d.getTime())) return null;
    return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  function dateRange(start, end) {
    const startStr = formatDate(start);
    if (!startStr) return null;
    const endStr = formatDate(end);
    if (endStr && endStr !== startStr) return `${startStr} – ${endStr}`;
    return startStr;
  }

  async function init() {
    // Session is already verified server-side; load bookings by the signed-in email.
    if (userEmail) {
      loadBookings(userEmail);
    } else {
      window.location.href = '/login';
    }
  }

  async function loadBookings(email) {
    if (!bookingSection) return;

    const { data: bookings, error } = await supabase
      .from('bookings')
      .select('*')
      .eq('customer_email', email)
      .order('created_at', { ascending: false });

    if (error) {
      console.error('Error loading bookings:', error);
      bookingSection.innerHTML = '<p class="text-red-500">Error loading bookings.</p>';
      return;
    }

    if (!bookings || bookings.length === 0) {
      bookingSection.innerHTML = `
        <div class="text-center py-8">
          <p class="text-gray-500 mb-4">You don't have any bookings yet.</p>
          <a href="/richiesta" class="inline-flex items-center px-5 py-3 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-black hover:bg-gray-800 focus:outline-none">
            Book Chef Nino
          </a>
        </div>
      `;
      return;
    }

    bookingSection.innerHTML = '';
    const list = document.createElement('div');
    list.className = 'space-y-6';

    for (const booking of bookings) {
      const plan = booking.plan || '';
      const packageName = (PRODUCTS[plan] && PRODUCTS[plan].name) || (plan ? plan : 'Bespoke');

      const statusKey = booking.status || 'pending';
      const statusLabel = STATUS_LABELS[statusKey] || (statusKey.charAt(0).toUpperCase() + statusKey.slice(1));
      const statusStyle = STATUS_STYLES[statusKey] || 'bg-gray-100 text-gray-800';

      const range = dateRange(booking.start_date, booking.end_date);
      const guests = (booking.num_guests != null) ? `${booking.num_guests} guests` : null;
      const price = (booking.total_price != null) ? formatPrice(booking.total_price) : null;
      const city = booking.city || 'Your booking';

      // Pay-later: a pending booking with a payment link is ready to be paid.
      const canPayNow = statusKey === 'pending' && !!booking.payment_link_url;
      const isPaid = statusKey === 'confirmed' || statusKey === 'completed';

      const metaParts = [];
      if (range) metaParts.push(escapeHtml(range));
      if (guests) metaParts.push(escapeHtml(guests));
      const meta = metaParts.join(' • ');

      // Per-booking WhatsApp, prefilled with context so Chef Nino knows the subject.
      const waText = `Hi Chef Nino, I'm writing about my booking "${packageName}"${range ? ' on ' + range : ''}.`;

      const item = document.createElement('div');
      item.className = 'border border-gray-200 rounded-lg p-4 sm:p-6';
      item.innerHTML = `
        ${isPaid ? `<div class="mb-4 flex items-center gap-2 rounded-lg bg-green-50 border border-green-200 px-3 py-2 text-sm font-medium text-green-800">
          <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          Your booking is confirmed
        </div>` : ''}
        <div class="flex justify-between items-start gap-4">
          <div>
            <h4 class="text-lg font-bold text-gray-900">${escapeHtml(packageName)}</h4>
            <p class="text-sm text-gray-500 mt-1">${escapeHtml(city)}</p>
            ${meta ? `<p class="text-sm text-gray-500 mt-1">${meta}</p>` : ''}
          </div>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusStyle}">
            ${escapeHtml(statusLabel)}
          </span>
        </div>
        ${price ? `<div class="mt-4 pt-4 border-t border-gray-100 flex justify-between items-center">
          <span class="text-sm text-gray-500">${canPayNow ? 'To pay' : 'Total'}</span>
          <span class="text-base font-semibold text-gray-900">${escapeHtml(price)}</span>
        </div>` : ''}
        ${isPaid ? `<p class="mt-3 text-xs text-gray-400">Groceries are billed separately, at cost. Chef Nino will be in touch to plan the menu.</p>` : ''}
        <div class="mt-4 flex flex-col sm:flex-row gap-3">
          ${canPayNow ? `<a href="${escapeHtml(booking.payment_link_url)}" class="inline-flex items-center justify-center flex-1 px-6 py-3 rounded-lg text-sm font-semibold text-amber-300 bg-black hover:bg-gray-900 active:bg-gray-800 shadow-sm transition-colors">
            Pay now${price ? ' · ' + escapeHtml(price) : ''}
          </a>` : ''}
          <a href="${escapeHtml(waLink(waText))}" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 ${canPayNow ? '' : 'flex-1 '}px-5 py-3 rounded-lg text-sm font-semibold text-white bg-[#25D366] hover:bg-[#1ebe5a] active:bg-[#1aa550] shadow-sm transition-colors">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.748-.748zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
            ${canPayNow ? 'A question?' : 'Message Chef Nino'}
          </a>
        </div>
      `;
      list.appendChild(item);
    }
    bookingSection.appendChild(list);
  }

  // Logout
  logoutBtn?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/login';
  });

  init();
</script>
