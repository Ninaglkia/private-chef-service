---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// "La Carta" — chef's tasting menus in a swipeable carousel, one menu at a time.
// Dish photos will be added over time as real dishes are photographed at events.
export const prerender = true;

// Chef's tasting menus — sample compositions, refreshed with the seasons.
// price = indicative per-person price shown on the card. Sorted low → high.
import { TASTING_MENUS } from '../lib/tasting-menus';
---

<Layout
  title="La Carta — Tasting Menus | Nino's Private Chef"
  description="Fifteen menus from €25 to €400 per person — breakfast, brunch, aperitivo, lunch and dinner by a private chef, cooked fresh in your villa on Lake Como, in Milan and across Lombardy."
  bodyClass="bg-[#faf7f1] text-[#17130d]"
>
  <Header transparent={false} />

  <main class="pb-28">
    <!-- Masthead -->
    <section class="max-w-3xl mx-auto px-5 pt-32 pb-8 text-center">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="h-px w-8 bg-[#c6a15b]/60"></span>
        <span class="text-[11px] uppercase tracking-[0.25em] text-[#c6a15b]">La Carta</span>
        <span class="h-px w-8 bg-[#c6a15b]/60"></span>
      </div>
      <h1 class="font-serif text-5xl sm:text-6xl font-semibold leading-tight">Menus by Chef Nino</h1>
      <p class="mt-4 text-gray-500 max-w-xl mx-auto">
        Fifteen menus, from €25 to €400 per person — breakfast, lunch, aperitivo and dinner: swipe through and find yours,
        or use one as a starting point: the final menu is always designed around you.
      </p>
      <p class="mt-3 text-[12px] text-gray-400">Menu priced per person · chef service €600 per event — covering menu design, shopping &amp; ingredients, cooking at your villa, service and a spotless kitchen</p>
    </section>

    <!-- Menu carousel: one menu per view, scroll-snap -->
    <section class="relative max-w-5xl mx-auto">
      <div id="menu-track" class="flex gap-5 overflow-x-auto snap-x snap-mandatory no-scrollbar px-[6vw] md:px-[18%] pb-4 scroll-smooth">
        {TASTING_MENUS.map((m, i) => (
          <article
            data-slide={i}
            class="menu-slide snap-center shrink-0 w-[88vw] max-w-[560px] rounded-3xl border border-[#e0cfa6] bg-[#fdfbf7] px-7 py-9 shadow-[0_10px_30px_rgba(31,26,18,0.07)]"
          >
            <p class="text-center text-[10px] uppercase tracking-[0.3em] text-[#8a8174]">Menu {['I','II','III','IV','V','VI','VII','VIII','IX','X','XI','XII','XIII','XIV','XV'][i]}</p>
            <h2 class="mt-1 text-center font-serif text-3xl text-[#17130d]">{m.name}</h2>
            <p class="text-center font-serif italic text-sm text-[#8a6c2f]">{m.tag}</p>
            <p class="mt-3 text-center font-serif text-xl text-[#17130d]">
              <span class="text-[#a07b35] font-semibold">€{m.price}</span>
              <span class="text-sm text-[#8a8174]"> per person</span><span class="block text-[11px] text-[#8a8174] mt-0.5">+ chef service €600{m.serviceExtraEur ? ` · ${m.serviceExtraLabel} €${m.serviceExtraEur}` : ''} per event{m.minGuests ? ` · minimum ${m.minGuests} guests` : ''}</span>
            </p>
            <div class="mx-auto my-5 h-px w-12 bg-[#c6a15b]"></div>
            <ul class="space-y-4">
              {m.courses.map((c) => (
                <li class="text-center">
                  <p class="text-[10px] uppercase tracking-[0.25em] text-[#a07b35]">{c.course}</p>
                  <p class="mt-0.5 font-serif text-[17px] leading-snug text-[#17130d]">{c.it}</p>
                  <p class="mt-0.5 text-[12px] italic text-[#8a8174]">{c.en}</p>
                </li>
              ))}
            </ul>
            <div class="mt-7 text-center">
              <a href={`/richiesta?menu=${encodeURIComponent(m.name)}`} class="inline-flex items-center gap-2 rounded-2xl bg-[#17130d] text-[#fdf8ef] px-6 py-3 text-sm font-serif tracking-wide hover:bg-black transition-all">
                <span class="text-[#c6a15b]">✦</span> Request this menu
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- Arrows (desktop) -->
      <button id="menu-prev" type="button" aria-label="Previous menu"
        class="hidden md:flex absolute left-4 top-1/2 -translate-y-1/2 w-11 h-11 items-center justify-center rounded-full bg-[#17130d] text-[#fdf8ef] shadow-lg hover:bg-black transition-colors">←</button>
      <button id="menu-next" type="button" aria-label="Next menu"
        class="hidden md:flex absolute right-4 top-1/2 -translate-y-1/2 w-11 h-11 items-center justify-center rounded-full bg-[#17130d] text-[#fdf8ef] shadow-lg hover:bg-black transition-colors">→</button>

      <!-- Dots -->
      <div id="menu-dots" class="mt-5 flex justify-center gap-2">
        {TASTING_MENUS.map((_, i) => (
          <button type="button" data-dot={i} aria-label={`Go to menu ${i + 1}`}
            class="menu-dot w-2.5 h-2.5 rounded-full bg-[#c6a15b]/30 transition-all"></button>
        ))}
      </div>
      <p class="mt-3 text-center text-[11px] text-gray-400 md:hidden">Swipe to browse the menus</p>
    </section>

    <div class="mt-12 text-center px-5">
      <p class="text-gray-500 text-sm">
        Prices are indicative per person — the final quote can be lower or higher, depending on your wishes, ingredients and season. Something different in mind?
        <a href="/richiesta" class="underline underline-offset-4 hover:text-[#a07b35]">Every menu is bespoke</a> — tell Chef Nino what you love.
      </p>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .menu-dot.active { background: #a07b35; transform: scale(1.35); }
</style>

<script>
  const track = document.getElementById('menu-track');
  const slides = Array.from(document.querySelectorAll<HTMLElement>('.menu-slide'));
  const dots = Array.from(document.querySelectorAll<HTMLElement>('.menu-dot'));
  let current = 0;

  function goTo(i: number) {
    const clamped = Math.max(0, Math.min(slides.length - 1, i));
    slides[clamped]?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
  }

  document.getElementById('menu-prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('menu-next')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));

  // Track the centered slide to light the matching dot.
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        current = Number((e.target as HTMLElement).dataset.slide || 0);
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
      });
    },
    { root: track, threshold: 0.6 }
  );
  slides.forEach((s) => observer.observe(s));
</script>
