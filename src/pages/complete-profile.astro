---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ProfileForm from '../components/ProfileForm.astro';

// Session resolved + refreshed in middleware → Astro.locals.user.
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect(`/login?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}
---

<Layout title="Complete Your Profile - Private Chef Service" bodyClass="bg-gray-50 text-gray-900">
  <Header transparent={false} />

  <div class="min-h-screen pt-24 pb-16 px-4 sm:px-6 lg:px-8 flex items-center justify-center">
    <div class="w-full max-w-lg">
      <ProfileForm mode="onboarding" />
    </div>
  </div>
</Layout>
