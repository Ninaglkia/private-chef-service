---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';

// Custom SSR error page. With output:'server', Astro serves this for any uncaught
// 500 instead of a bare, unbranded platform error screen — so a transient failure
// (e.g. a Supabase blip during checkout) still shows a branded page with a way out.
export const prerender = false;
---

<Layout title="Something went wrong | Private Chef" description="An unexpected error occurred.">
  <Header />

  <main class="min-h-[60vh] flex items-center justify-center pt-32 pb-20 bg-white">
    <div class="text-center px-6">
      <p class="text-gold-600 font-semibold tracking-wide uppercase mb-3">500</p>
      <h1 class="text-4xl md:text-5xl font-semibold text-gray-900 mb-4">Something went wrong</h1>
      <p class="text-lg text-gray-600 max-w-md mx-auto mb-8">
        We hit an unexpected error. Please try again in a moment — if it keeps happening,
        message Chef Nino directly and we'll sort it out right away.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/" size="lg">Back to Home</Button>
        <Button href="https://wa.me/393285515590" variant="outline" size="lg">Message Chef Nino</Button>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
