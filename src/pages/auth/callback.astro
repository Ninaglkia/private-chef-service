---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
---

<Layout title="Signing you in - Private Chef Service" bodyClass="bg-gray-50 text-gray-900">
  <Header transparent={false} />

  <div class="min-h-[100dvh] pt-24 pb-16 px-4 sm:px-6 lg:px-8 flex items-center justify-center">
    <div class="w-full max-w-md">
      <div class="bg-white/90 backdrop-blur-sm shadow-xl rounded-2xl p-6 sm:p-8 border border-gray-100 animate-fade-in text-center">
        <!-- Loading state -->
        <div id="callback-loading">
          <div class="flex justify-center">
            <svg class="h-10 w-10 animate-spin text-gold-400" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 0 1 8-8v4a4 4 0 0 0-4 4H4z"></path>
            </svg>
          </div>
          <h1 class="mt-5 text-xl sm:text-2xl font-bold tracking-tight text-gray-900">Signing you in…</h1>
          <p class="mt-2 text-sm text-gray-500">Hold on a moment while we finish setting up your session.</p>
        </div>

        <!-- Error state -->
        <div id="callback-error" class="hidden">
          <div class="flex justify-center">
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-red-50 text-red-500">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
              </svg>
            </span>
          </div>
          <h1 class="mt-5 text-xl sm:text-2xl font-bold tracking-tight text-gray-900">Sign-in failed</h1>
          <p id="callback-error-message" class="mt-2 text-sm text-red-500">We couldn't complete your sign-in.</p>
          <a
            href="/login"
            class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-black text-white py-3 text-sm font-semibold tracking-wide shadow-lg shadow-black/10 hover:bg-gray-900 active:scale-[0.99] transition-all duration-200"
          >
            <span>Back to login</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../../lib/supabase';

  const loadingBox = document.getElementById('callback-loading');
  const errorBox = document.getElementById('callback-error');
  const errorMessage = document.getElementById('callback-error-message');

  function showError(message: string) {
    if (errorMessage && message) errorMessage.textContent = message;
    loadingBox?.classList.add('hidden');
    errorBox?.classList.remove('hidden');
  }

  // Sanitize returnTo so it can never point off-site or back at /login,
  // /signup, /complete-profile or /auth/callback (recursion guard).
  // Mirrors login.astro's handlePostAuthRedirect logic.
  function sanitizeReturnTo(rawReturnTo: string | null): string {
    let target = rawReturnTo || '/dashboard';
    if (
      !target.startsWith('/') ||
      target.startsWith('//') ||
      target.startsWith('/login') ||
      target.startsWith('/signup') ||
      target.startsWith('/complete-profile') ||
      target.startsWith('/auth/callback')
    ) {
      target = '/dashboard';
    }
    return target;
  }

  async function finalizeLogin() {
    const url = new URL(window.location.href);

    // 1. Surface any OAuth error returned by the provider / Supabase.
    const oauthError = url.searchParams.get('error_description') || url.searchParams.get('error');
    if (oauthError) {
      showError(decodeURIComponent(oauthError));
      return;
    }

    const returnToParam = url.searchParams.get('returnTo');

    // 2. Exchange the PKCE ?code= for a session. detectSessionInUrl may have
    // already done this, so tolerate the "already exchanged"/no-code case.
    try {
      const { error: exchangeError } = await supabase.auth.exchangeCodeForSession(window.location.href);
      if (exchangeError) {
        const msg = exchangeError.message || '';
        const alreadyHandled =
          /code verifier/i.test(msg) ||
          /both auth code and code verifier/i.test(msg) ||
          /invalid request/i.test(msg) ||
          /no.*code/i.test(msg);
        // If the code was already consumed (detectSessionInUrl), a session may
        // still exist — fall through and check getSession() before erroring.
        if (!alreadyHandled) {
          // Non-recoverable exchange error — but still try getSession() as a last resort.
        }
      }
    } catch (e) {
      // Ignore and fall through to the getSession() check below.
    }

    // 3. Confirm we actually have a session.
    const { data: { session } } = await supabase.auth.getSession();
    const user = session?.user;
    if (!user || !session) {
      showError('We could not complete your sign-in. Please try again.');
      return;
    }

    // 4. Set cookies for server-side auth (valid for 7 days) —
    // EXACTLY as login.astro's handlePostAuthRedirect does.
    const maxAge = 60 * 60 * 24 * 7;
    document.cookie = `sb-access-token=${session.access_token}; path=/; max-age=${maxAge}; SameSite=Lax; Secure`;
    document.cookie = `sb-refresh-token=${session.refresh_token}; path=/; max-age=${maxAge}; SameSite=Lax; Secure`;

    // 5. Onboarding gate — same logic as login.astro.
    const { data: profile } = await supabase
      .from('profiles')
      .select('full_name, phone, city')
      .eq('id', user.id)
      .maybeSingle();

    const onboardingComplete = !!(profile && profile.full_name && profile.phone && profile.city);

    const target = sanitizeReturnTo(returnToParam);

    if (!onboardingComplete) {
      window.location.href = `/complete-profile?returnTo=${encodeURIComponent(target)}`;
      return;
    }

    window.location.href = target;
  }

  finalizeLogin().catch((e) => {
    showError(e?.message || 'An unexpected error occurred. Please try again.');
  });
</script>
