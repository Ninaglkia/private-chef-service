---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Set New Password - Private Chef Service" bodyClass="bg-gray-50 text-gray-900">
  <Header transparent={false} />

  <div class="min-h-[100dvh] pt-24 pb-16 px-4 sm:px-6 lg:px-8 flex items-center justify-center">
    <div class="w-full max-w-md">
      <div class="bg-white/90 backdrop-blur-sm shadow-xl rounded-2xl p-6 sm:p-8 border border-gray-100 animate-fade-in">
        <div class="mb-6 text-center">
          <h1 class="text-2xl font-bold tracking-tight text-gray-900">Set New Password</h1>
          <p class="mt-2 text-sm text-gray-500">Choose a new secure password for your account.</p>
        </div>

        <form class="space-y-4" id="reset-form">
          <div class="space-y-2">
            <label for="password" class="block text-xs font-semibold text-gray-700 tracking-wide">New Password</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="10" rx="2" ry="2" />
                  <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
              </span>
              <input
                id="password"
                name="password"
                type="password"
                required
                minlength="6"
                class="block w-full rounded-lg border border-gray-300 bg-white pl-10 pr-3 py-3 text-base sm:text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-black focus:border-black transition-all"
                placeholder="At least 6 characters"
              />
            </div>
          </div>

          <div class="space-y-2">
            <label for="confirm_password" class="block text-xs font-semibold text-gray-700 tracking-wide">Confirm Password</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="10" rx="2" ry="2" />
                  <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
              </span>
              <input
                id="confirm_password"
                name="confirm_password"
                type="password"
                required
                minlength="6"
                class="block w-full rounded-lg border border-gray-300 bg-white pl-10 pr-3 py-3 text-base sm:text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-black focus:border-black transition-all"
                placeholder="Repeat your password"
              />
            </div>
          </div>

          <button
            id="reset-submit"
            type="submit"
            class="w-full mt-2 inline-flex items-center justify-center gap-2 rounded-xl bg-black text-white py-3 text-sm font-semibold tracking-wide shadow-lg shadow-black/10 hover:bg-gray-900 active:scale-[0.99] transition-all duration-200"
          >
            <span>Update Password</span>
          </button>

          <p id="reset-message" class="mt-2 text-sm text-center hidden"></p>
        </form>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  const form = document.getElementById('reset-form') as HTMLFormElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const confirmInput = document.getElementById('confirm_password') as HTMLInputElement;
  const submitBtn = document.getElementById('reset-submit') as HTMLButtonElement;
  const messageBox = document.getElementById('reset-message') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitBtn) submitBtn.disabled = true;
    if (messageBox) {
        messageBox.classList.add('hidden');
        messageBox.classList.remove('text-red-500', 'text-green-600');
    }

    const password = passwordInput.value;
    const confirm = confirmInput.value;

    if (password !== confirm) {
        if (messageBox) {
            messageBox.textContent = 'The passwords do not match.';
            messageBox.classList.add('text-red-500');
            messageBox.classList.remove('hidden');
        }
        submitBtn.disabled = false;
        return;
    }

    try {
        const { error } = await supabase.auth.updateUser({ password: password });

        if (error) throw error;

        if (messageBox) {
            messageBox.textContent = 'Password updated successfully! Redirecting...';
            messageBox.classList.add('text-green-600');
            messageBox.classList.remove('hidden');
        }
        
        setTimeout(() => {
            window.location.href = '/dashboard';
        }, 2000);

    } catch (err: any) {
        if (messageBox) {
            messageBox.textContent = err.message;
            messageBox.classList.add('text-red-500');
            messageBox.classList.remove('hidden');
        }
        submitBtn.disabled = false;
    }
  });

  // Guard: this page only works with an active recovery session (set when the
  // user arrives via the reset link / /auth/confirm). If someone lands here
  // without one — direct visit or an expired link — don't leave them at a raw
  // "Auth session missing!" dead-end after submitting: tell them and point to
  // /forgot-password. Re-enable if a session arrives (implicit-flow links).
  function showExpiredReset() {
    if (messageBox) {
      messageBox.innerHTML =
        'This reset link is invalid or has expired. ' +
        '<a href="/forgot-password" class="font-semibold underline">Request a new one</a>.';
      messageBox.classList.add('text-red-500');
      messageBox.classList.remove('hidden');
    }
    if (submitBtn) submitBtn.disabled = true;
  }

  supabase.auth.onAuthStateChange((_event, session) => {
    if (session && submitBtn) {
      submitBtn.disabled = false;
      if (messageBox && (messageBox.textContent || '').includes('expired')) {
        messageBox.classList.add('hidden');
      }
    }
  });

  supabase.auth.getSession().then(({ data: { session } }) => {
    if (!session) showExpiredReset();
  });
</script>