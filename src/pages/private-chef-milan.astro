---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';

// Local-SEO landing: "private chef milan" and neighbourhood long-tail queries.
export const prerender = true;

const AREAS = ['Brera', 'Porta Nuova', 'City Life', 'Navigli', 'Porta Romana', 'Sempione', 'Isola', 'Magenta', 'Duomo'];

const FAQS = [
  {
    q: 'Do you cook in our apartment in Milan?',
    a: "Yes — Chef Nino shops, cooks in your kitchen, serves and leaves everything spotless. Dinner parties, anniversaries, business dinners: the restaurant comes to you.",
  },
  {
    q: 'How much does a private chef in Milan cost?',
    a: 'Every event is quoted personally: a chef fee (half or full day) plus a per-guest amount for the menu. Send your date and number of guests, and Nino replies with a bespoke menu and price — no payment upfront.',
  },
  {
    q: 'Can you cater a business dinner or a small office event?',
    a: 'Yes — intimate business dinners, team celebrations and private tastings are a specialty. English-speaking service for international guests.',
  },
  {
    q: 'Which neighbourhoods do you serve?',
    a: `All of Milan — ${AREAS.slice(0, 6).join(', ')} and beyond — plus Monza, Como and the rest of Lombardy.`,
  },
  {
    q: 'Do you handle dietary requirements?',
    a: 'Of course: vegetarian, vegan, gluten-free, allergies, kids — mention them in your request and the menu is built around them.',
  },
];
---

<Layout
  title="Private Chef in Milan — At-Home Fine Dining | Nino's Private Chef"
  description="Premium private chef in Milan: bespoke menus cooked in your home in Brera, Porta Nuova, City Life, Navigli and all of Milan. Dinner parties and business dinners. Request a personal proposal — no payment upfront."
  bodyClass="bg-[#faf7f1] text-[#17130d]"
>
  <Header transparent={false} />

  <main class="pb-24">
    <section class="max-w-3xl mx-auto px-5 pt-32 pb-10 text-center">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="h-px w-8 bg-[#c6a15b]/60"></span>
        <span class="text-[11px] uppercase tracking-[0.25em] text-[#c6a15b]">Milano</span>
        <span class="h-px w-8 bg-[#c6a15b]/60"></span>
      </div>
      <h1 class="font-serif text-4xl sm:text-6xl font-semibold leading-tight">Private Chef in Milan</h1>
      <p class="mt-5 text-gray-600 leading-relaxed">
        Fine dining at your own table. Chef Nino brings the kitchen to your home —
        from Brera to Navigli, City Life to Porta Romana — for dinner parties,
        anniversaries and business dinners that feel effortless.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <Button href="/richiesta" size="lg">Request a proposal</Button>
        <Button href="/menu" variant="outline" size="lg">Browse La Carta</Button>
      </div>
    </section>

    <section class="max-w-3xl mx-auto px-5 py-8">
      <div class="flex items-center gap-4 mb-5">
        <span class="font-serif text-2xl text-[#c6a15b]">✦</span>
        <h2 class="font-serif text-2xl font-semibold">Where Nino cooks in the city</h2>
        <span class="h-px flex-1 bg-[#c6a15b]/25"></span>
      </div>
      <p class="text-gray-600 leading-relaxed">
        {AREAS.join(' · ')} — and all around Milan, Monza included. An apartment,
        a penthouse terrace or a courtyard loft: if there's a kitchen, there's a dinner.
      </p>
    </section>

    <section class="max-w-3xl mx-auto px-5 py-8">
      <div class="flex items-center gap-4 mb-6">
        <span class="font-serif text-2xl text-[#c6a15b]">✦</span>
        <h2 class="font-serif text-2xl font-semibold">Questions guests ask</h2>
        <span class="h-px flex-1 bg-[#c6a15b]/25"></span>
      </div>
      <div class="space-y-4">
        {FAQS.map((f) => (
          <details class="group rounded-2xl border border-[#c6a15b]/25 bg-white p-5">
            <summary class="cursor-pointer font-medium list-none flex justify-between items-center gap-3">
              {f.q}
              <span class="text-[#c6a15b] transition-transform group-open:rotate-45">+</span>
            </summary>
            <p class="mt-3 text-gray-600 text-sm leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="max-w-3xl mx-auto px-5 pt-10 text-center">
      <h2 class="font-serif text-3xl font-semibold">Your dinner in Milan starts here</h2>
      <p class="mt-3 text-gray-600">Tell Nino your date, your guests and your idea — he replies personally with menu and price.</p>
      <div class="mt-6">
        <Button href="/richiesta" size="lg">Request a proposal</Button>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
