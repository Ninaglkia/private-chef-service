---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';

// Local-SEO landing: "private chef lake como" and long-tail town queries.
export const prerender = true;

const TOWNS = ['Bellagio', 'Cernobbio', 'Tremezzo', 'Menaggio', 'Varenna', 'Laglio', 'Moltrasio', 'Como', 'Lenno', 'Argegno'];

const FAQS = [
  {
    q: 'Do you cook in our rental villa on Lake Como?',
    a: "Yes — that's the heart of the service. Chef Nino shops, cooks in your villa's kitchen, serves, and leaves everything spotless. You enjoy the lake, the table is taken care of.",
  },
  {
    q: 'How much does a private chef on Lake Como cost?',
    a: 'Every event is quoted personally: the chef fee depends on the day (half or full day), plus a per-guest amount for the menu. Send a request with your date and guests, and Nino replies with a bespoke menu and price — no payment upfront.',
  },
  {
    q: 'Can you do a multi-day stay or a full week?',
    a: 'Yes. Many guests book Chef Nino for their whole stay — breakfast to dinner, menus that never repeat. Weekly arrangements are quoted as a package.',
  },
  {
    q: 'Which towns do you serve?',
    a: `All of Lake Como, including ${TOWNS.slice(0, 6).join(', ')} and the smaller villages — plus Milan and the rest of Lombardy.`,
  },
  {
    q: 'Do you handle dietary requirements?',
    a: 'Of course: vegetarian, vegan, gluten-free, allergies, kids — mention them in your request and the menu is built around them.',
  },
];
---

<Layout
  title="Private Chef on Lake Como — Bellagio, Cernobbio, Tremezzo | Nino's Private Chef"
  description="Premium private chef for your Lake Como villa: bespoke menus cooked in your kitchen in Bellagio, Cernobbio, Tremezzo, Menaggio, Varenna and all around the lake. Request a personal proposal — no payment upfront."
  bodyClass="bg-[#faf7f1] text-[#17130d]"
>
  <Header transparent={false} />

  <main class="pb-24">
    <section class="max-w-3xl mx-auto px-5 pt-32 pb-10 text-center">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="h-px w-8 bg-[#c6a15b]/60"></span>
        <span class="text-[11px] uppercase tracking-[0.25em] text-[#c6a15b]">Lake Como</span>
        <span class="h-px w-8 bg-[#c6a15b]/60"></span>
      </div>
      <h1 class="font-serif text-4xl sm:text-6xl font-semibold leading-tight">Private Chef on Lake Como</h1>
      <p class="mt-5 text-gray-600 leading-relaxed">
        A table set by the water, a menu created for you, and nothing to think about.
        Chef Nino cooks in your villa — from Bellagio to Cernobbio, Tremezzo to Varenna —
        bringing restaurant-level dining to the most beautiful terraces of the lake.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <Button href="/richiesta" size="lg">Request a proposal</Button>
        <Button href="/menu" variant="outline" size="lg">Browse La Carta</Button>
      </div>
    </section>

    <section class="max-w-3xl mx-auto px-5 py-8">
      <div class="flex items-center gap-4 mb-5">
        <span class="font-serif text-2xl text-[#c6a15b]">✦</span>
        <h2 class="font-serif text-2xl font-semibold">Where Nino cooks on the lake</h2>
        <span class="h-px flex-1 bg-[#c6a15b]/25"></span>
      </div>
      <p class="text-gray-600 leading-relaxed">
        {TOWNS.join(' · ')} — and every village in between. Staying in a rental villa,
        a family home or a boutique apartment? If there's a kitchen, there's a dinner.
      </p>
    </section>

    <section class="max-w-3xl mx-auto px-5 py-8">
      <div class="flex items-center gap-4 mb-6">
        <span class="font-serif text-2xl text-[#c6a15b]">✦</span>
        <h2 class="font-serif text-2xl font-semibold">Questions guests ask</h2>
        <span class="h-px flex-1 bg-[#c6a15b]/25"></span>
      </div>
      <div class="space-y-4">
        {FAQS.map((f) => (
          <details class="group rounded-2xl border border-[#c6a15b]/25 bg-white p-5">
            <summary class="cursor-pointer font-medium list-none flex justify-between items-center gap-3">
              {f.q}
              <span class="text-[#c6a15b] transition-transform group-open:rotate-45">+</span>
            </summary>
            <p class="mt-3 text-gray-600 text-sm leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="max-w-3xl mx-auto px-5 pt-10 text-center">
      <h2 class="font-serif text-3xl font-semibold">Your evening on the lake starts here</h2>
      <p class="mt-3 text-gray-600">Tell Nino your date, your guests and your idea — he replies personally with menu and price.</p>
      <div class="mt-6">
        <Button href="/richiesta" size="lg">Request a proposal</Button>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
