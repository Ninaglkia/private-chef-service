---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { PRODUCT_LIST, CUSTOM_PLAN, formatPrice, MAX_GUESTS } from '../lib/pricing';
import { EUROPEAN_COUNTRIES } from '../lib/european-data';
import { createClient } from '@supabase/supabase-js';

// Service area: Lombardy (and lake towns). Abroad is handled as a quote.
const LOMBARDY_CITIES = [
  'Milano', 'Monza', 'Bergamo', 'Brescia', 'Como', 'Varese', 'Pavia',
  'Cremona', 'Mantova', 'Lecco', 'Lodi', 'Sondrio', 'Sesto San Giovanni',
  'Cinisello Balsamo', 'Legnano', 'Gallarate', 'Busto Arsizio', 'Vigevano',
  'Rho', 'Saronno', 'Desenzano del Garda', 'Sirmione', 'Salò', 'Gardone Riviera',
  'Bellagio', 'Menaggio', 'Cernobbio', 'Tremezzina', 'Iseo', 'Franciacorta',
];

// Server-side route protection
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const supabase = createClient(supabaseUrl, supabaseAnonKey, {
  auth: { persistSession: false, autoRefreshToken: false },
});

const accessToken = Astro.cookies.get('sb-access-token')?.value;

if (!accessToken) {
  const returnTo = Astro.url.pathname + Astro.url.search;
  return Astro.redirect(`/login?returnTo=${encodeURIComponent(returnTo)}`);
}

const { data: { user }, error } = await supabase.auth.getUser(accessToken);

if (error || !user) {
  const returnTo = Astro.url.pathname + Astro.url.search;
  return Astro.redirect(`/login?returnTo=${encodeURIComponent(returnTo)}`);
}

// Onboarding gate: a complete profile (name, phone, city) is required to continue.
// Read via the service-role key (server-only) so RLS / auth-context never blocks
// this read and cause a redirect loop with /complete-profile.
const supabaseAdmin = createClient(supabaseUrl, import.meta.env.SUPABASE_SERVICE_ROLE_KEY, {
  auth: { persistSession: false, autoRefreshToken: false },
});
const { data: profile, error: profileError } = await supabaseAdmin
  .from('profiles')
  .select('full_name, phone, city')
  .eq('id', user.id)
  .maybeSingle();
// Fail OPEN on query error to avoid redirect loops; only gate when we can read the profile.
if (!profileError) {
  const incomplete = !profile || !profile.full_name || !profile.phone || !profile.city;
  if (incomplete) {
    const returnTo = Astro.url.pathname + Astro.url.search;
    return Astro.redirect('/complete-profile?returnTo=' + encodeURIComponent(returnTo));
  }
}

const preselectedGuests = Astro.url.searchParams.get('guests');
const selectedProduct = Astro.url.searchParams.get('product'); // day | weekend | week | custom

function cadenceLabel(days: number): string {
  if (days >= 7) return 'per week';
  if (days === 2) return 'per weekend';
  return 'per day';
}
---

<Layout title="Book Your Private Chef | Private Chef">
  <Header />

  <main class="pt-32 pb-20 bg-white min-h-screen">
    <div class="container mx-auto px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
          <h1 class="text-4xl md:text-5xl font-semibold text-gray-900 mb-6">
            Book Your Private Chef
          </h1>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Choose your package and dates — same price for up to {MAX_GUESTS} guests.
          </p>
        </div>

        <div class="bg-white rounded-2xl shadow-soft-xl p-8 md:p-12 border border-gray-200">
          <form id="booking-form">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">

              <!-- Package selector -->
              <div class="col-span-1 md:col-span-2 space-y-3">
                <label class="block text-sm font-bold text-gray-900">Choose your package *</label>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4" id="product-selector">
                  {PRODUCT_LIST.map((p) => (
                    <label
                      class="product-card relative flex flex-col p-5 bg-gray-50 rounded-xl border-2 border-gray-200 cursor-pointer hover:border-gold-400 transition-all duration-200"
                      data-product={p.id}
                    >
                      <input type="radio" name="product" value={p.id} class="sr-only product-radio" checked={selectedProduct === p.id} />
                      {p.highlight && (
                        <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gold-500 text-white text-[11px] font-bold uppercase tracking-wide px-3 py-1 rounded-full">Best value</span>
                      )}
                      <span class="text-base font-bold text-gray-900">{p.name}</span>
                      <span class="mt-1 text-2xl font-bold text-gray-900">{formatPrice(p.priceCents)}</span>
                      <span class="text-xs text-gray-500">{cadenceLabel(p.days)}</span>
                      <span class="mt-2 text-xs text-gray-600">{p.tagline}</span>
                    </label>
                  ))}
                  <label
                    class="product-card relative flex flex-col p-5 bg-gray-50 rounded-xl border-2 border-gray-200 cursor-pointer hover:border-gold-400 transition-all duration-200"
                    data-product="custom"
                  >
                    <input type="radio" name="product" value="custom" class="sr-only product-radio" checked={selectedProduct === 'custom'} />
                    <span class="text-base font-bold text-gray-900">{CUSTOM_PLAN.name}</span>
                    <span class="mt-1 text-2xl font-bold text-gray-900">By quote</span>
                    <span class="text-xs text-gray-500">15+ guests / abroad</span>
                    <span class="mt-2 text-xs text-gray-600">{CUSTOM_PLAN.tagline}</span>
                  </label>
                </div>
                <p class="text-sm text-gray-500">Up to {MAX_GUESTS} guests — same price. Groceries billed separately, at cost. Service in Lombardy; elsewhere quoted on request.</p>
              </div>

              <!-- Personal details -->
              <div class="space-y-2">
                <label for="customer_name" class="block text-sm font-bold text-gray-900">Full Name *</label>
                <input type="text" id="customer_name" name="customer_name" required class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-gold-400 focus:border-gold-400 transition-all duration-200 text-lg bg-gray-50 focus:bg-white" placeholder="John Smith" />
              </div>

              <div class="space-y-2">
                <label for="customer_email" class="block text-sm font-bold text-gray-900">Email Address *</label>
                <input type="email" id="customer_email" name="customer_email" required class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-gold-400 focus:border-gold-400 transition-all duration-200 text-lg bg-gray-50 focus:bg-white" placeholder="john@example.com" />
              </div>

              <!-- Phone & City -->
              <div class="space-y-2">
                <label for="phone_number_local" class="block text-sm font-bold text-gray-900">Phone Number</label>
                <div class="flex flex-col md:flex-row gap-3">
                  <div class="relative" id="country-selector">
                    <input type="hidden" name="phone_country_code" id="phone_country_code" value="+39">
                    <button type="button" id="country-trigger" class="w-full md:w-[140px] px-4 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-gold-400 focus:border-gold-400 bg-gray-50 focus:bg-white flex items-center justify-between gap-2 transition-all duration-200 h-[64px]">
                      <span class="flex items-center gap-2">
                        <span id="selected-flag" class="text-xl">🇮🇹</span>
                        <span id="selected-dial-code" class="text-gray-900 font-medium">+39</span>
                      </span>
                      <svg class="w-4 h-4 text-gray-500 transition-transform duration-200" id="country-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                    </button>
                    <div id="country-dropdown" class="hidden absolute top-full left-0 mt-2 w-80 max-h-80 overflow-y-auto bg-white border border-gray-200 rounded-xl shadow-xl z-50">
                      <div class="p-3 sticky top-0 bg-white border-b border-gray-100 z-10">
                        <input type="text" id="country-search" placeholder="Search country..." class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:border-gold-400 transition-colors">
                      </div>
                      <ul class="py-1">
                        {EUROPEAN_COUNTRIES.map((country) => (
                          <li>
                            <button type="button" class="country-option w-full px-4 py-2.5 text-left hover:bg-gray-50 flex items-center gap-3 transition-colors border-b border-gray-50 last:border-0" data-code={country.dial_code} data-flag={country.flag} data-name={country.name.toLowerCase()}>
                              <span class="text-2xl">{country.flag}</span>
                              <span class="flex-1 text-gray-900 font-medium">{country.name}</span>
                              <span class="text-gray-500 text-sm font-mono">{country.dial_code}</span>
                            </button>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                  <div class="flex-1 relative">
                    <input type="tel" id="phone_number_local" name="phone_number_local" class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-gold-400 focus:border-gold-400 transition-all duration-200 text-lg bg-gray-50 focus:bg-white h-[64px]" placeholder="333 123 4567" />
                    <div id="phone-validation-msg" class="absolute -bottom-6 left-0 text-xs text-red-500 hidden">Please enter a valid phone number</div>
                  </div>
                </div>
              </div>

              <div class="space-y-2">
                <label for="city" class="block text-sm font-bold text-gray-900">City *</label>
                <div id="city-picker" class="relative" data-cities={JSON.stringify(LOMBARDY_CITIES)}>
                  <select id="city" name="city" required class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-gold-400 focus:border-gold-400 transition-all duration-200 text-lg appearance-none bg-gray-50 focus:bg-white cursor-pointer h-[64px]">
                    <option value="" disabled selected>Select a city</option>
                    {LOMBARDY_CITIES.map((c) => (<option value={c}>{c}</option>))}
                  </select>
                  <div id="city-select-icon" class="absolute inset-y-0 right-0 flex items-center px-5 pointer-events-none text-gray-500"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg></div>

                  <div id="city-enhanced" class="hidden">
                    <div class="relative">
                      <input id="city-search" type="text" inputmode="search" autocomplete="off" spellcheck="false" class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-gold-400 focus:border-gold-400 transition-all duration-200 text-lg bg-gray-50 focus:bg-white h-[64px]" placeholder="Type to filter cities..." role="combobox" aria-autocomplete="list" aria-expanded="false" aria-controls="city-listbox" />
                      <button type="button" id="city-clear" class="hidden absolute right-4 top-1/2 -translate-y-1/2 h-8 w-8 rounded-lg hover:bg-gray-100 active:bg-gray-200 transition-colors text-gray-500 flex items-center justify-center" aria-label="Clear city">
                        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 6L6 18M6 6l12 12" /></svg>
                      </button>
                    </div>

                    <div id="city-dropdown" class="hidden absolute top-full left-0 mt-2 w-full max-h-[50vh] overflow-y-auto bg-white border border-gray-200 rounded-xl shadow-xl z-50">
                      <div id="city-loading" class="px-4 py-3 text-sm text-gray-500 flex items-center gap-2">
                        <span class="inline-block h-4 w-4 border-2 border-gray-300 border-t-transparent rounded-full animate-spin"></span>
                        <span>Loading cities…</span>
                      </div>
                      <div id="city-error" class="hidden px-4 py-3 text-sm text-red-600"></div>
                      <div id="city-empty" class="hidden px-4 py-3 text-sm text-gray-500">No cities found.</div>
                      <ul id="city-listbox" role="listbox" class="py-1"></ul>
                    </div>

                    <div id="city-feedback" class="hidden mt-2 text-xs text-gray-500"></div>
                  </div>
                </div>
                <p class="mt-2 text-xs text-gray-500">Outside Lombardy? Choose “Abroad &amp; Bespoke” above for a tailored quote.</p>
              </div>

              <!-- Start date -->
              <div class="space-y-2 relative">
                <label for="start_date" class="block text-sm font-bold text-gray-900">Start Date *</label>
                <div class="relative">
                  <input type="text" id="start_date" name="start_date" required readonly placeholder="Select your start date" class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-gold-400 focus:border-gold-400 transition-all duration-200 text-lg cursor-pointer bg-gray-50 focus:bg-white h-[64px]" />
                  <svg class="absolute right-5 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>

                  <div id="calendar-container" class="hidden absolute left-0 z-50 mt-2 bg-white rounded-2xl shadow-2xl border-2 border-gray-200 p-6 w-[400px] max-w-[95vw]">
                    <div class="flex items-center justify-between mb-6">
                      <button type="button" id="prev-month" class="p-2 hover:bg-gray-100 rounded-lg transition-colors"><svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg></button>
                      <h3 id="calendar-month-year" class="text-lg font-semibold text-gray-900"></h3>
                      <button type="button" id="next-month" class="p-2 hover:bg-gray-100 rounded-lg transition-colors"><svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg></button>
                    </div>
                    <div class="grid grid-cols-7 gap-2 mb-3">
                      <div class="text-center text-xs font-semibold text-gray-600 py-2">Mon</div>
                      <div class="text-center text-xs font-semibold text-gray-600 py-2">Tue</div>
                      <div class="text-center text-xs font-semibold text-gray-600 py-2">Wed</div>
                      <div class="text-center text-xs font-semibold text-gray-600 py-2">Thu</div>
                      <div class="text-center text-xs font-semibold text-gray-600 py-2">Fri</div>
                      <div class="text-center text-xs font-semibold text-gray-600 py-2">Sat</div>
                      <div class="text-center text-xs font-semibold text-gray-600 py-2">Sun</div>
                    </div>
                    <div id="calendar-days" class="grid grid-cols-7 gap-2 mb-4"></div>
                  </div>
                </div>
                <p class="mt-2 text-sm text-gray-500" id="date-help-text">Pick the day your service starts</p>
              </div>

              <div class="space-y-2">
                <label for="num_guests" class="block text-sm font-bold text-gray-900">Number of Guests *</label>
                <select id="num_guests" name="num_guests" required class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-gold-400 focus:border-gold-400 transition-all duration-200 text-lg bg-gray-50 focus:bg-white h-[64px]">
                  <option value="">Select number of guests</option>
                  <option value="1">1 guest</option>
                  <option value="2">2 guests</option>
                  <option value="3">3 guests</option>
                  <option value="4">4 guests</option>
                  <option value="5">5 guests</option>
                  <option value="6">6 guests</option>
                  <option value="7">7 guests</option>
                  <option value="8">8 guests</option>
                  <option value="9">9 guests</option>
                  <option value="10">10 guests</option>
                  <option value="11">11 guests</option>
                  <option value="12">12 guests</option>
                  <option value="13">13 guests</option>
                  <option value="14">14 guests</option>
                  <option value="15">15 guests</option>
                </select>
                <p class="mt-1 text-xs text-gray-500">More than {MAX_GUESTS}? Choose “Abroad &amp; Bespoke” for a quote.</p>
              </div>

              <!-- Notes -->
              <div class="col-span-1 md:col-span-2 space-y-2">
                <label for="dietary_preferences" id="notes-label" class="block text-sm font-bold text-gray-900">Dietary Preferences &amp; Allergies</label>
                <textarea id="dietary_preferences" name="dietary_preferences" rows="4" class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-gold-400 focus:border-gold-400 transition-all duration-200 text-lg bg-gray-50 focus:bg-white" placeholder="Please specify any dietary restrictions, allergies, or food preferences..."></textarea>
              </div>

              <!-- Price -->
              <div id="price-section" class="col-span-1 md:col-span-2 bg-gray-50 rounded-xl p-8 border border-gray-200">
                <div class="flex justify-between items-center mb-2">
                  <span class="text-lg font-bold text-gray-900">Total Price</span>
                  <span id="total-price" class="text-4xl font-bold text-gray-900">€0</span>
                </div>
                <div id="price-breakdown" class="text-base text-gray-600 space-y-1">
                  <p>Select a package to see the price</p>
                </div>
                <p class="mt-3 text-sm text-gray-500">Groceries are billed separately, at cost.</p>
              </div>

              <!-- Custom quote notice -->
              <div id="quote-notice" class="hidden col-span-1 md:col-span-2 bg-gradient-to-br from-gold-50 to-yellow-50 border-2 border-gold-300 rounded-xl p-6">
                <h3 class="font-bold text-gray-900 text-lg mb-2">Abroad &amp; Bespoke — by quote</h3>
                <p class="text-gray-700 text-sm">Tell us your dates, location and group size. We'll reply within 24 hours with a tailored quote (travel &amp; accommodation arranged per destination, or provide a room for the chef — no extra cost).</p>
              </div>

              <!-- Policy -->
              <div class="col-span-1 md:col-span-2 bg-white rounded-xl p-6 border border-gray-200 shadow-sm">
                <div class="flex items-start">
                  <svg class="w-6 h-6 text-gold-500 mr-4 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  <div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2">Booking Confirmation Policy</h3>
                    <p class="text-sm text-gray-600 mb-3">When you complete your booking and payment, your request is subject to confirmation.</p>
                    <ul class="space-y-2 text-sm text-gray-600">
                      <li class="flex items-start"><svg class="w-4 h-4 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span>All bookings are confirmed within 48 hours</span></li>
                      <li class="flex items-start"><svg class="w-4 h-4 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span>If we cannot serve your selected dates, you receive a full automatic refund</span></li>
                      <li class="flex items-start"><svg class="w-4 h-4 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg><span>Groceries are billed separately, at cost</span></li>
                    </ul>
                  </div>
                </div>
              </div>

              <!-- GDPR -->
              <div class="col-span-1 md:col-span-2 flex items-start pt-2">
                <input type="checkbox" id="gdpr_consent" name="gdpr_consent" required class="w-5 h-5 mt-1 text-gold-600 border-gray-300 rounded focus:ring-gold-400" />
                <label for="gdpr_consent" class="ml-3 text-sm text-gray-600 leading-relaxed">
                  I agree to the <a href="/terms" class="text-gold-600 underline font-medium hover:text-gold-700">Terms &amp; Conditions</a> and <a href="/privacy" class="text-gold-600 underline font-medium hover:text-gold-700">Privacy Policy</a>. *
                </label>
              </div>

              <!-- Submit -->
              <div class="col-span-1 md:col-span-2 space-y-3">
                <button type="submit" id="submit-button" class="w-full bg-gray-900 text-white py-4 rounded-xl font-bold text-lg hover:bg-gray-800 transition-colors duration-300 disabled:opacity-50 disabled:cursor-not-allowed shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">Proceed to Payment</button>
                <p class="text-center text-sm text-gray-500 flex items-center justify-center gap-2">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9v-2h2v2zm0-4H9V7h2v5z"/></svg>
                  Secure payment powered by Stripe
                </p>
              </div>

            </div>
          </form>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import { PRODUCTS, formatPrice, isValidProduct, type Product } from '../lib/pricing';

  const numGuestsSelect = document.getElementById('num_guests') as HTMLSelectElement;
  const totalPriceElement = document.getElementById('total-price');
  const priceBreakdownElement = document.getElementById('price-breakdown');
  const bookingForm = document.getElementById('booking-form') as HTMLFormElement;
  const startDateInput = document.getElementById('start_date') as HTMLInputElement;
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
  const priceSection = document.getElementById('price-section');
  const quoteNotice = document.getElementById('quote-notice');
  const notesLabel = document.getElementById('notes-label');
  const notesTextarea = document.getElementById('dietary_preferences') as HTMLTextAreaElement;
  const calendarContainer = document.getElementById('calendar-container');
  const calendarDays = document.getElementById('calendar-days');
  const calendarMonthYear = document.getElementById('calendar-month-year');
  const prevMonthButton = document.getElementById('prev-month');
  const nextMonthButton = document.getElementById('next-month');
  const dateHelpText = document.getElementById('date-help-text');
  const productRadios = Array.from(document.querySelectorAll('.product-radio')) as HTMLInputElement[];
  const productCards = Array.from(document.querySelectorAll('.product-card')) as HTMLElement[];

  type Selection = Product | 'custom';
  let currentProduct: Selection | null = null;
  let startDate: Date | null = null;
  let endDate: Date | null = null;
  let currentMonth = new Date().getMonth();
  let currentYear = new Date().getFullYear();

  // ---- Date helpers ----
  function formatDateForDisplay(date: Date): string {
    return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  }
  function formatDateRange(start: Date, end: Date): string {
    if (formatDateForSubmit(start) === formatDateForSubmit(end)) return formatDateForDisplay(start);
    return `${formatDateForDisplay(start)} – ${formatDateForDisplay(end)}`;
  }
  function formatDateForSubmit(date: Date): string {
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
  }
  function isFutureDate(date: Date): boolean {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    return date >= today;
  }
  function isDateInRange(date: Date, start: Date, end: Date): boolean {
    return date >= start && date <= end;
  }
  function productDays(): number {
    if (currentProduct && currentProduct !== 'custom') return PRODUCTS[currentProduct].days;
    return 1;
  }
  function computeEndDate(start: Date): Date {
    const end = new Date(start);
    end.setDate(start.getDate() + (productDays() - 1));
    return end;
  }

  function refreshDateField() {
    if (!startDate) return;
    endDate = computeEndDate(startDate);
    startDateInput.value = formatDateRange(startDate, endDate);
    startDateInput.setAttribute('data-start-date', formatDateForSubmit(startDate));
    startDateInput.setAttribute('data-end-date', formatDateForSubmit(endDate));
    const days = productDays();
    if (dateHelpText) {
      dateHelpText.textContent = currentProduct === 'custom'
        ? `Event date: ${formatDateForDisplay(startDate)}`
        : `${days} day${days > 1 ? 's' : ''} of service: ${formatDateRange(startDate, endDate)}`;
    }
  }

  // ---- Calendar ----
  function renderCalendar() {
    if (!calendarDays || !calendarMonthYear) return;

    const firstDay = new Date(currentYear, currentMonth, 1);
    const lastDay = new Date(currentYear, currentMonth + 1, 0);
    const prevLastDay = new Date(currentYear, currentMonth, 0);
    const firstDayIndex = (firstDay.getDay() + 6) % 7;
    const lastDayIndex = (lastDay.getDay() + 6) % 7;
    const nextDays = lastDayIndex === 6 ? 0 : 6 - lastDayIndex;

    const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    calendarMonthYear.textContent = `${months[currentMonth]} ${currentYear}`;

    let days = '';
    for (let x = firstDayIndex; x > 0; x--) {
      const day = prevLastDay.getDate() - x + 1;
      days += `<div class="text-center py-3 text-sm text-gray-300">${day}</div>`;
    }

    for (let i = 1; i <= lastDay.getDate(); i++) {
      const date = new Date(currentYear, currentMonth, i);
      const selectable = isFutureDate(date);
      const isStart = !!(startDate && formatDateForSubmit(date) === formatDateForSubmit(startDate));
      const isEnd = !!(endDate && formatDateForSubmit(date) === formatDateForSubmit(endDate));
      const inRange = !!(startDate && endDate && isDateInRange(date, startDate, endDate) && !isStart && !isEnd);

      let classes = 'text-center py-3 text-sm rounded-lg transition-all duration-200 ';
      if (isStart) {
        classes += 'bg-gray-900 text-white font-bold shadow-lg ring-2 ring-gray-900 ring-offset-2';
      } else if (isEnd) {
        classes += 'bg-gold-500 text-white font-bold shadow-lg ring-2 ring-gold-500 ring-offset-2';
      } else if (inRange) {
        classes += 'bg-gold-100 text-gray-900 font-medium';
      } else if (selectable) {
        classes += 'text-gray-900 font-medium cursor-pointer hover:bg-gold-100 hover:scale-105 hover:shadow-md border-2 border-gold-300';
      } else {
        classes += 'text-gray-300 cursor-not-allowed';
      }
      const dataAttr = selectable ? `data-date="${formatDateForSubmit(date)}"` : '';
      days += `<div class="${classes}" ${dataAttr}>${i}</div>`;
    }

    for (let j = 1; j <= nextDays; j++) {
      days += `<div class="text-center py-3 text-sm text-gray-300">${j}</div>`;
    }

    calendarDays.innerHTML = days;

    calendarDays.querySelectorAll('[data-date]').forEach((dayElement) => {
      dayElement.addEventListener('click', (e) => {
        e.stopPropagation();
        const dateStr = dayElement.getAttribute('data-date');
        if (!dateStr) return;
        const [year, month, day] = dateStr.split('-').map(Number);
        startDate = new Date(year, month - 1, day);
        refreshDateField();
        renderCalendar();
        calendarContainer?.classList.add('hidden');
      });
    });
  }

  startDateInput.addEventListener('click', (e) => {
    e.stopPropagation();
    if (!calendarContainer?.classList.contains('hidden')) {
      calendarContainer?.classList.add('hidden');
    } else {
      if (startDate) { currentMonth = startDate.getMonth(); currentYear = startDate.getFullYear(); }
      calendarContainer?.classList.remove('hidden');
      renderCalendar();
    }
  });
  calendarContainer?.addEventListener('click', (e) => e.stopPropagation());
  document.addEventListener('click', (e) => {
    if (!calendarContainer?.contains(e.target as Node) && e.target !== startDateInput) {
      calendarContainer?.classList.add('hidden');
    }
  });
  prevMonthButton?.addEventListener('click', (e) => {
    e.stopPropagation();
    currentMonth--; if (currentMonth < 0) { currentMonth = 11; currentYear--; }
    renderCalendar();
  });
  nextMonthButton?.addEventListener('click', (e) => {
    e.stopPropagation();
    currentMonth++; if (currentMonth > 11) { currentMonth = 0; currentYear++; }
    renderCalendar();
  });

  // ---- Product selection ----
  function applyCardStyles() {
    productCards.forEach((card) => {
      const radio = card.querySelector('.product-radio') as HTMLInputElement | null;
      if (radio?.checked) {
        card.classList.add('border-gold-500', 'bg-gold-50');
        card.classList.remove('border-gray-200', 'bg-gray-50');
      } else {
        card.classList.remove('border-gold-500', 'bg-gold-50');
        card.classList.add('border-gray-200', 'bg-gray-50');
      }
    });
  }

  function updateProduct() {
    const selected = productRadios.find((r) => r.checked);
    currentProduct = (selected?.value as Selection) || null;
    applyCardStyles();

    if (!currentProduct) {
      priceSection?.classList.remove('hidden');
      quoteNotice?.classList.add('hidden');
      totalPriceElement!.textContent = '€0';
      priceBreakdownElement!.innerHTML = '<p>Select a package to see the price</p>';
      submitButton.textContent = 'Proceed to Payment';
      return;
    }

    if (currentProduct === 'custom') {
      priceSection?.classList.add('hidden');
      quoteNotice?.classList.remove('hidden');
      submitButton.textContent = 'Request a Quote';
      notesLabel!.textContent = 'Tell us about your event';
      notesTextarea.placeholder = 'Group size, location, dates, dietary needs, special requests…';
    } else {
      priceSection?.classList.remove('hidden');
      quoteNotice?.classList.add('hidden');
      submitButton.textContent = 'Proceed to Payment';
      notesLabel!.textContent = 'Dietary Preferences & Allergies';
      notesTextarea.placeholder = 'Please specify any dietary restrictions, allergies, or food preferences...';

      const details = PRODUCTS[currentProduct];
      totalPriceElement!.textContent = formatPrice(details.priceCents);
      const cadence = details.days >= 7 ? 'week' : details.days === 2 ? 'weekend' : 'day';
      priceBreakdownElement!.innerHTML = `<p>${details.name} — ${formatPrice(details.priceCents)} per ${cadence}</p><p>Up to 15 guests, same price.</p>`;
    }

    // Re-derive the end date for the (possibly) new duration.
    refreshDateField();
  }

  productRadios.forEach((r) => r.addEventListener('change', updateProduct));

  // ---- Submit ----
  bookingForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!currentProduct) {
      alert('Please choose a package');
      return;
    }
    const startDateValue = startDateInput.getAttribute('data-start-date');
    if (!startDateValue) {
      alert('Please select your start date');
      return;
    }

    const formData = new FormData(bookingForm);
    const numGuests = parseInt((numGuestsSelect.value || '1'), 10);
    const phoneCountryCode = formData.get('phone_country_code');
    const phoneNumberLocal = formData.get('phone_number_local');
    const fullPhone = (phoneCountryCode && phoneNumberLocal)
      ? `${phoneCountryCode} ${phoneNumberLocal}`
      : null;

    submitButton.disabled = true;
    const originalLabel = submitButton.textContent;
    submitButton.textContent = 'Processing...';

    try {
      if (currentProduct === 'custom') {
        const quoteData = {
          customer_name: formData.get('customer_name'),
          customer_email: formData.get('customer_email'),
          customer_phone: fullPhone,
          city: formData.get('city'),
          start_date: startDateValue,
          num_guests: numGuests,
          notes: formData.get('dietary_preferences') || '',
        };
        const response = await fetch('/api/request-quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(quoteData),
        });
        const result = await response.json();
        if (result.error) throw new Error(result.error);
        window.location.href = '/confirmation?quote_id=' + result.id;
      } else {
        const bookingData = {
          customer_name: formData.get('customer_name'),
          customer_email: formData.get('customer_email'),
          customer_phone: fullPhone,
          city: formData.get('city'),
          start_date: startDateValue,
          num_guests: numGuests,
          product: currentProduct,
          dietary_preferences: formData.get('dietary_preferences') || '',
        };
        const response = await fetch('/api/create-checkout-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(bookingData),
        });
        const result = await response.json();
        if (result.error) throw new Error(result.error);
        if (result.url) window.location.href = result.url;
      }
    } catch (error) {
      console.error('Error:', error);
      alert('An error occurred. Please try again.');
      submitButton.disabled = false;
      submitButton.textContent = originalLabel;
    }
  });

  // ---- URL params + init ----
  const urlParams = new URLSearchParams(window.location.search);
  const preselectedGuests = urlParams.get('guests');
  if (preselectedGuests && numGuestsSelect) {
    const n = parseInt(preselectedGuests, 10);
    if (!Number.isNaN(n) && n >= 1 && n <= 15) numGuestsSelect.value = String(n);
  }

  renderCalendar();
  updateProduct();

  // --- Phone number selector ---
  const countrySelector = document.getElementById('country-selector');
  const countryTrigger = document.getElementById('country-trigger');
  const countryDropdown = document.getElementById('country-dropdown');
  const countrySearch = document.getElementById('country-search') as HTMLInputElement;
  const countryOptions = document.querySelectorAll('.country-option');
  const hiddenInput = document.getElementById('phone_country_code') as HTMLInputElement;
  const selectedFlag = document.getElementById('selected-flag');
  const selectedDialCode = document.getElementById('selected-dial-code');
  const countryArrow = document.getElementById('country-arrow');
  const phoneInput = document.getElementById('phone_number_local') as HTMLInputElement;
  const phoneValidationMsg = document.getElementById('phone-validation-msg');

  countryTrigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = countryDropdown?.classList.contains('hidden');
    if (isHidden) {
      countryDropdown?.classList.remove('hidden');
      countryArrow?.classList.add('rotate-180');
      countrySearch?.focus();
    } else {
      closeDropdown();
    }
  });

  function closeDropdown() {
    countryDropdown?.classList.add('hidden');
    countryArrow?.classList.remove('rotate-180');
    if (countrySearch) countrySearch.value = '';
    filterCountries('');
  }

  document.addEventListener('click', (e) => {
    if (countrySelector && !countrySelector.contains(e.target as Node)) closeDropdown();
  });

  function filterCountries(query: string) {
    const lowerQuery = query.toLowerCase();
    countryOptions.forEach((option) => {
      const name = option.getAttribute('data-name') || '';
      const code = option.getAttribute('data-code') || '';
      (option.parentElement as HTMLElement).style.display =
        name.includes(lowerQuery) || code.includes(lowerQuery) ? 'block' : 'none';
    });
  }

  countrySearch?.addEventListener('input', (e) => filterCountries((e.target as HTMLInputElement).value));

  countryOptions.forEach((option) => {
    option.addEventListener('click', () => {
      const code = option.getAttribute('data-code');
      const flag = option.getAttribute('data-flag');
      if (code && flag) {
        hiddenInput.value = code;
        if (selectedFlag) selectedFlag.textContent = flag;
        if (selectedDialCode) selectedDialCode.textContent = code;
        countryOptions.forEach((opt) => opt.classList.remove('bg-gold-50'));
        option.classList.add('bg-gold-50');
        closeDropdown();
        phoneInput?.focus();
      }
    });
  });

  phoneInput?.addEventListener('input', (e) => {
    const input = e.target as HTMLInputElement;
    input.value = input.value.replace(/[^0-9]/g, '');
    validatePhone();
  });

  function validatePhone() {
    if (!phoneInput) return false;
    const value = phoneInput.value;
    const isValid = value.length >= 7 && value.length <= 15;
    if (value.length > 0 && !isValid) {
      phoneInput.classList.add('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
      phoneInput.classList.remove('border-gray-200', 'focus:border-gold-400', 'focus:ring-gold-400');
      phoneValidationMsg?.classList.remove('hidden');
      return false;
    }
    phoneInput.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500');
    phoneInput.classList.add('border-gray-200', 'focus:border-gold-400', 'focus:ring-gold-400');
    phoneValidationMsg?.classList.add('hidden');
    return isValid;
  }
  phoneInput?.addEventListener('blur', validatePhone);

  // --- City picker (searchable combobox with native <select> fallback) ---
  (function initCityPicker() {
    const picker = document.getElementById('city-picker') as HTMLElement | null;
    const select = document.getElementById('city') as HTMLSelectElement | null;
    const selectIcon = document.getElementById('city-select-icon') as HTMLElement | null;
    const enhanced = document.getElementById('city-enhanced') as HTMLElement | null;
    const input = document.getElementById('city-search') as HTMLInputElement | null;
    const dropdown = document.getElementById('city-dropdown') as HTMLElement | null;
    const listbox = document.getElementById('city-listbox') as HTMLUListElement | null;
    const loading = document.getElementById('city-loading') as HTMLElement | null;
    const empty = document.getElementById('city-empty') as HTMLElement | null;
    const error = document.getElementById('city-error') as HTMLElement | null;
    const feedback = document.getElementById('city-feedback') as HTMLElement | null;
    const clearBtn = document.getElementById('city-clear') as HTMLButtonElement | null;

    if (!picker || !select || !enhanced || !input || !dropdown || !listbox || !loading || !empty || !error || !feedback || !clearBtn) {
      return;
    }

    let cities: Array<{ name: string; lower: string }> = [];
    try {
      const raw = picker.getAttribute('data-cities');
      const parsed = raw ? JSON.parse(raw) : [];
      if (!Array.isArray(parsed)) throw new Error('Invalid city dataset');
      cities = parsed
        .filter((c) => typeof c === 'string' && c.trim().length > 0)
        .map((name) => ({ name, lower: name.toLowerCase() }));
    } catch (e) {
      enhanced.classList.remove('hidden');
      dropdown.classList.remove('hidden');
      loading.classList.add('hidden');
      empty.classList.add('hidden');
      error.textContent = 'Error loading city list.';
      error.classList.remove('hidden');
      return;
    }

    enhanced.classList.remove('hidden');
    select.classList.add('sr-only');
    if (selectIcon) selectIcon.classList.add('hidden');
    const label = picker.parentElement?.querySelector('label[for="city"]') as HTMLLabelElement | null;
    if (label) {
      label.htmlFor = 'city-search';
      if (!label.id) label.id = 'city-label';
      select.setAttribute('aria-labelledby', label.id);
      input.setAttribute('aria-labelledby', label.id);
    }

    let isOpen = false;
    let activeIndex = -1;
    let filtered: Array<{ name: string; lower: string }> = cities;
    let renderToken = 0;

    const setOpen = (next: boolean) => {
      isOpen = next;
      if (isOpen) {
        dropdown.classList.remove('hidden');
        input.setAttribute('aria-expanded', 'true');
      } else {
        dropdown.classList.add('hidden');
        input.setAttribute('aria-expanded', 'false');
        activeIndex = -1;
      }
    };

    const setFeedback = (text: string) => {
      feedback.textContent = text;
      feedback.classList.remove('hidden');
    };

    const setActive = (idx: number) => {
      const options = Array.from(listbox.querySelectorAll('[role="option"]')) as HTMLElement[];
      options.forEach((el) => el.classList.remove('bg-gold-50'));
      if (idx < 0 || idx >= options.length) { activeIndex = -1; return; }
      activeIndex = idx;
      const el = options[idx];
      el.classList.add('bg-gold-50');
      el.scrollIntoView({ block: 'nearest' });
    };

    const selectCity = (name: string) => {
      select.value = name;
      input.value = name;
      input.setCustomValidity('');
      clearBtn.classList.toggle('hidden', input.value.trim().length === 0);
      setOpen(false);
    };

    const renderList = (lowerQuery: string) => {
      listbox.innerHTML = '';
      if (filtered.length === 0) {
        empty.classList.remove('hidden');
        setFeedback('0 results');
        input.classList.add('border-red-300');
        return;
      }
      input.classList.remove('border-red-300');
      empty.classList.add('hidden');

      const frag = document.createDocumentFragment();
      const max = Math.min(filtered.length, 80);
      for (let i = 0; i < max; i++) {
        const name = filtered[i].name;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'w-full px-4 py-3 text-left text-sm text-gray-900 hover:bg-gray-50 active:bg-gray-100 transition-colors';
        btn.setAttribute('role', 'option');
        btn.setAttribute('aria-selected', 'false');
        if (lowerQuery) {
          const prefixLen = Math.min(lowerQuery.length, name.length);
          btn.innerHTML = `<span class="font-semibold">${name.slice(0, prefixLen)}</span>${name.slice(prefixLen)}`;
        } else {
          btn.textContent = name;
        }
        btn.addEventListener('click', () => selectCity(name));
        const li = document.createElement('li');
        li.appendChild(btn);
        frag.appendChild(li);
      }
      listbox.appendChild(frag);
      setFeedback(`${filtered.length} results`);
    };

    const update = (query: string) => {
      const token = ++renderToken;
      const q = query.trim().toLowerCase();
      loading.classList.remove('hidden');
      error.classList.add('hidden');
      empty.classList.add('hidden');
      setOpen(true);

      requestAnimationFrame(() => {
        if (token !== renderToken) return;
        filtered = q ? cities.filter((c) => c.lower.startsWith(q)) : cities;
        loading.classList.add('hidden');
        renderList(q);
      });
    };

    const trySelectExactMatch = () => {
      const q = input.value.trim().toLowerCase();
      if (!q) return;
      const exact = cities.find((c) => c.lower === q);
      if (exact) selectCity(exact.name);
    };

    input.addEventListener('focus', () => {
      clearBtn.classList.toggle('hidden', input.value.trim().length === 0);
      update(input.value);
    });
    input.addEventListener('input', () => {
      clearBtn.classList.toggle('hidden', input.value.trim().length === 0);
      update(input.value);
    });
    input.addEventListener('keydown', (e) => {
      const optionsCount = listbox.querySelectorAll('[role="option"]').length;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (!isOpen) update(input.value);
        setActive(Math.min(activeIndex + 1, optionsCount - 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(Math.max(activeIndex - 1, 0));
      } else if (e.key === 'Enter') {
        if (!isOpen) return;
        e.preventDefault();
        const opts = Array.from(listbox.querySelectorAll('[role="option"]')) as HTMLElement[];
        const el = opts[activeIndex];
        const name = el?.textContent?.trim();
        if (name) selectCity(name);
        else { trySelectExactMatch(); setOpen(false); }
      } else if (e.key === 'Escape') {
        e.preventDefault();
        setOpen(false);
      }
    });

    clearBtn.addEventListener('click', () => {
      input.value = '';
      select.value = '';
      input.setCustomValidity('');
      clearBtn.classList.add('hidden');
      update('');
      input.focus();
    });

    document.addEventListener('click', (e) => {
      if (!picker.contains(e.target as Node)) {
        setOpen(false);
        trySelectExactMatch();
      }
    });

    bookingForm?.addEventListener('submit', (e) => {
      if (!select.value) {
        input.setCustomValidity('Select a city');
        input.reportValidity();
        setOpen(true);
        e.preventDefault();
      } else {
        input.setCustomValidity('');
      }
    });

    if (select.value) {
      input.value = select.value;
      clearBtn.classList.toggle('hidden', input.value.trim().length === 0);
      setFeedback('Selected');
    } else {
      feedback.classList.add('hidden');
    }
  })();
</script>
