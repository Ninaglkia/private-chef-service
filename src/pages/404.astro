---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
---

<Layout title="Page Not Found | Private Chef" description="The page you are looking for doesn't exist.">
  <Header />

  <main class="min-h-[60vh] flex items-center justify-center pt-32 pb-20 bg-white">
    <div class="text-center px-6">
      <p class="text-gold-600 font-semibold tracking-wide uppercase mb-3">404</p>
      <h1 class="text-4xl md:text-5xl font-semibold text-gray-900 mb-4">Page not found</h1>
      <p class="text-lg text-gray-600 max-w-md mx-auto mb-8">
        The page you are looking for doesn't exist or has moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/" size="lg">Back to Home</Button>
        <Button href="/richiesta" variant="outline" size="lg">Book a Chef</Button>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
