---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ProfileForm from '../components/ProfileForm.astro';
import { isOwnerEmail } from '../lib/admin';

// Session resolved + refreshed in middleware → Astro.locals.user.
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect(`/login?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}

// The owner manages everything from the /owner console.
if (isOwnerEmail(user.email)) {
  return Astro.redirect('/owner');
}
---

<Layout title="My Profile - Private Chef Service" bodyClass="bg-gray-50 text-gray-900">
  <Header transparent={false} />

  <div class="min-h-screen pt-24 pb-16 px-4 sm:px-6 lg:px-8 flex items-center justify-center">
    <div class="w-full max-w-lg">
      <div class="mb-4">
        <a href="/dashboard" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-900 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          Back to dashboard
        </a>
      </div>
      <ProfileForm mode="edit" email={user.email} />
    </div>
  </div>
</Layout>
