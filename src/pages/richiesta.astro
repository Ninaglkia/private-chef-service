---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

// Experience carousel. NOTE: images are placeholders (existing photos) until the
// AI-generated experience images are added under /images/experiences/.
const EXPERIENCES = [
  { label: 'Cena in villa', img: '/images/dish1.jpg' },
  { label: 'Cena romantica', img: '/images/dish2.jpg' },
  { label: 'Evento / festa', img: '/images/team.jpg' },
  { label: 'Chef per più giorni', img: '/images/chef.jpg' },
  { label: 'Menù di pesce', img: '/images/dish2.jpg' },
  { label: 'Altro', img: '' },
];
---

<Layout title="Richiedi Chef Nino - Private Chef" bodyClass="bg-[#faf7f1] text-gray-900">
  <Header transparent={false} />

  <section class="min-h-[100dvh] pt-28 pb-20 px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold-600">Su misura per te</p>
        <h1 class="mt-2 font-serif text-3xl sm:text-4xl font-semibold text-gray-900">Racconta il tuo evento</h1>
        <p class="mt-3 text-gray-500">Dicci com'è la tua idea: Chef Nino la legge e ti ricontatta con la proposta e il prezzo. Nessun pacchetto fisso — su misura.</p>
      </div>

      <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-6 sm:p-8">
        <form id="request-form" class="space-y-5" novalidate>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="customer_name" class="block text-xs font-semibold text-gray-700 mb-1">Nome e cognome *</label>
              <input id="customer_name" name="customer_name" type="text" required
                class="block w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-base text-gray-900 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500"
                placeholder="Nome Cognome" />
            </div>
            <div>
              <label for="customer_phone" class="block text-xs font-semibold text-gray-700 mb-1">Telefono *</label>
              <input id="customer_phone" name="customer_phone" type="tel" required
                class="block w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-base text-gray-900 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500"
                placeholder="+39 333 1234567" />
            </div>
          </div>

          <div>
            <label for="customer_email" class="block text-xs font-semibold text-gray-700 mb-1">Email *</label>
            <input id="customer_email" name="customer_email" type="email" required
              class="block w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-base text-gray-900 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500"
              placeholder="tu@esempio.com" />
          </div>

          <div>
            <label class="block text-xs font-semibold text-gray-700 mb-2">Quale esperienza ti interessa? *</label>
            <div class="flex gap-3 overflow-x-auto pb-2 -mx-1 px-1 snap-x">
              {EXPERIENCES.map((ex) => (
                <button
                  type="button"
                  class="exp-card snap-start shrink-0 w-40 rounded-xl overflow-hidden border-2 border-gray-200 bg-white shadow-sm text-left transition-all hover:shadow-md focus:outline-none"
                  data-service={ex.label}
                >
                  {ex.img ? (
                    <span class="block h-24 w-full bg-cover bg-center" style={`background-image:url(${ex.img})`}></span>
                  ) : (
                    <span class="flex h-24 w-full items-center justify-center bg-gradient-to-br from-gray-100 to-gray-200 text-gray-400">
                      <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg>
                    </span>
                  )}
                  <span class="exp-label block px-3 py-2 text-sm font-semibold text-gray-800">{ex.label}</span>
                </button>
              ))}
            </div>
            <input type="hidden" id="service_type" name="service_type" />
            <p id="exp-error" class="mt-1 text-xs text-red-500 hidden">Scegli un'esperienza.</p>
          </div>

          <div>
            <label for="num_guests" class="block text-xs font-semibold text-gray-700 mb-1">Per quante persone? *</label>
            <input id="num_guests" name="num_guests" type="number" min="1" max="200" required
              class="block w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-base text-gray-900 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500"
              placeholder="es. 6" />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="start_date" class="block text-xs font-semibold text-gray-700 mb-1">Quando? *</label>
              <input id="start_date" name="start_date" type="date" required
                class="block w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-base text-gray-900 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500" />
            </div>
            <div>
              <label for="city" class="block text-xs font-semibold text-gray-700 mb-1">Dove? *</label>
              <input id="city" name="city" type="text" required
                class="block w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-base text-gray-900 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500"
                placeholder="Città (e indirizzo se vuoi)" />
            </div>
          </div>

          <div>
            <label for="event_details" class="block text-xs font-semibold text-gray-700 mb-1">Raccontami la tua idea</label>
            <textarea id="event_details" name="event_details" rows="5"
              class="block w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-base text-gray-900 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500"
              placeholder="Occasione, tipo di menù, preferenze o allergie, budget indicativo…"></textarea>
          </div>

          <!-- Honeypot -->
          <input type="text" name="company_website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

          <label class="flex items-start gap-2 text-xs text-gray-600">
            <input id="consent" type="checkbox" required class="mt-0.5 h-4 w-4 rounded border-gray-300 text-gold-600 focus:ring-gold-500" />
            <span>Autorizzo il trattamento dei miei dati per essere ricontattato riguardo a questa richiesta.</span>
          </label>

          <button id="request-submit" type="submit"
            class="w-full inline-flex items-center justify-center gap-2 rounded-xl bg-[#17130d] text-white py-3.5 text-sm font-semibold tracking-wide shadow-lg hover:bg-black active:scale-[0.99] transition-all disabled:opacity-60">
            <span id="request-submit-label">Invia la richiesta</span>
            <span id="request-spinner" class="hidden h-4 w-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
          </button>
          <p id="request-error" class="text-sm text-red-500 hidden"></p>
        </form>

        <!-- Success state -->
        <div id="request-success" class="hidden text-center py-6">
          <div class="flex justify-center">
            <span class="flex h-14 w-14 items-center justify-center rounded-full bg-green-50 text-green-600">
              <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </span>
          </div>
          <h2 class="mt-5 font-serif text-2xl font-semibold text-gray-900">Richiesta inviata! 🎉</h2>
          <p class="mt-2 text-gray-500">Grazie — Chef Nino ha ricevuto la tua idea e ti ricontatterà a breve con la proposta e il prezzo.</p>
          <a href="/" class="mt-6 inline-block rounded-xl border border-gray-300 px-5 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50">Torna alla home</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('request-form') as HTMLFormElement | null;
  const successBox = document.getElementById('request-success');
  const errorBox = document.getElementById('request-error') as HTMLParagraphElement | null;
  const submitBtn = document.getElementById('request-submit') as HTMLButtonElement | null;
  const spinner = document.getElementById('request-spinner');
  const serviceInput = document.getElementById('service_type') as HTMLInputElement | null;
  const expError = document.getElementById('exp-error');

  // Experience carousel selection.
  document.querySelectorAll('.exp-card').forEach((card) => {
    card.addEventListener('click', () => {
      const el = card as HTMLElement;
      if (serviceInput) serviceInput.value = el.getAttribute('data-service') || '';
      document.querySelectorAll('.exp-card').forEach((c) => {
        c.classList.remove('border-gold-500', 'ring-2', 'ring-gold-400');
        c.classList.add('border-gray-200');
      });
      el.classList.remove('border-gray-200');
      el.classList.add('border-gold-500', 'ring-2', 'ring-gold-400');
      expError?.classList.add('hidden');
    });
  });

  function showError(msg: string) {
    if (!errorBox) return;
    errorBox.textContent = msg;
    errorBox.classList.remove('hidden');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorBox?.classList.add('hidden');
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    if (!serviceInput || !serviceInput.value) {
      expError?.classList.remove('hidden');
      expError?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    const fd = new FormData(form);
    const payload = {
      customer_name: String(fd.get('customer_name') || '').trim(),
      customer_email: String(fd.get('customer_email') || '').trim(),
      customer_phone: String(fd.get('customer_phone') || '').trim(),
      service_type: String(fd.get('service_type') || '').trim(),
      num_guests: String(fd.get('num_guests') || '').trim(),
      start_date: String(fd.get('start_date') || '').trim(),
      city: String(fd.get('city') || '').trim(),
      event_details: String(fd.get('event_details') || '').trim(),
      marketing_consent: true,
      product: 'custom',
      company_website: String(fd.get('company_website') || ''),
    };

    if (submitBtn) submitBtn.disabled = true;
    spinner?.classList.remove('hidden');

    try {
      const res = await fetch('/api/request-booking', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        showError(data?.error || 'Invio non riuscito, riprova.');
        if (submitBtn) submitBtn.disabled = false;
        spinner?.classList.add('hidden');
        return;
      }
      form.classList.add('hidden');
      successBox?.classList.remove('hidden');
      successBox?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } catch {
      showError('Errore di rete, riprova.');
      if (submitBtn) submitBtn.disabled = false;
      spinner?.classList.add('hidden');
    }
  });
</script>
