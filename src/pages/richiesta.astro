---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { COUNTRIES } from '../lib/countries';

export const prerender = false;

// Experience slideshow. Dedicated photography under /images/experiences/.
const EXPERIENCES = [
  { label: 'Dinner at your villa', img: '/images/experiences/villa.jpg', kicker: 'The evening', desc: 'A table under the stars, by your poolside', price: 'Menus from €50 per person', filter: 'dinner', link: '#details', linkLabel: 'Request' },
  { label: 'Romantic dinner', img: '/images/experiences/romantic.jpg', kicker: 'For two', desc: 'An intimate menu, by candlelight', price: 'La Romantica — €110 per person', filter: 'La Romantica', link: '/richiesta?menu=La%20Romantica', linkLabel: 'Request' },
  { label: 'Aperitivo & events', img: '/images/experiences/event.jpg', kicker: 'With everyone', desc: 'Spritz, bites and golden hour for your party', price: 'From €28 pp · min 8 guests · waiter included', filter: "L'Aperitivo Italiano", link: '/richiesta?menu=L%27Aperitivo%20Italiano', linkLabel: 'Request' },
  { label: 'From the sea', img: '/images/experiences/seafood.jpg', kicker: 'Raw & cooked', desc: 'Crudi, risotto and the salt-crust theatre', price: 'Il Mare — €95 per person', filter: "Il Mare,Il Gran Gourmet,L'Imperiale", link: '/richiesta?menu=Il%20Mare', linkLabel: 'Request' },
  { label: 'Chef for several days', img: '/images/experiences/multiday.jpg', kicker: 'At your home', desc: 'Breakfast to dinner, for your whole stay', price: 'Personal weekly quote', filter: 'all', link: '#details', linkLabel: 'Tell Chef Nino your dates' },
];

// NOTE: availability is intentionally NOT managed in the website. The guest only
// states a preferred date (or range); Chef Nino confirms feasibility off-site (his
// own calendar / WhatsApp). So there is no "unavailable dates" logic here.
---

<Layout
  title="Request a Private Chef — Lake Como & Milan | Nino's Private Chef"
  description="Request your bespoke private chef experience on Lake Como, in Milan or across Lombardy — personal menu and price within 24h, no payment upfront, no account needed."
  bodyClass="bg-[#faf7f1] text-[#17130d]">
  <Header transparent={false} />

  <!-- Slim reading-progress bar: fills as you move through the page -->
  <div class="fixed top-0 left-0 right-0 z-[55] h-[3px] bg-transparent pointer-events-none">
    <div id="progress-fill" class="h-full w-0 bg-[#c6a15b] transition-[width] duration-150 ease-out"></div>
  </div>

  <main class="overflow-x-hidden">
    <!-- MASTHEAD -->
    <section class="max-w-3xl mx-auto px-5 pt-32 pb-12 text-center">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="h-px w-8 bg-[#c6a15b]/60"></span>
        <span class="text-[11px] uppercase tracking-[0.25em] text-[#c6a15b]">Bespoke</span>
        <span class="h-px w-8 bg-[#c6a15b]/60"></span>
      </div>
      <h1 class="font-serif text-5xl sm:text-6xl font-semibold leading-tight">Let's design your evening.</h1>
      <p class="mt-4 text-gray-500 max-w-xl mx-auto">Tell Chef Nino about the evening you have in mind and he'll reply with a bespoke proposal and price. No payment now — no account needed.</p>
      <p class="mt-3 text-sm text-gray-500">Not sure yet? <a href="/menu" class="underline underline-offset-4 text-[#a07b35] hover:text-[#8a6c2f]">Browse the menus</a> — from €50 per person.</p>
    </section>

    <!-- CHAPTER 01 — L'ESPERIENZA -->
    <div class="max-w-3xl mx-auto px-5">
      <div class="flex items-center gap-4">
        <span class="font-serif text-2xl text-[#c6a15b]">I</span>
        <span class="text-xs uppercase tracking-[0.2em] text-[#17130d]/70">The experience</span>
        <span class="h-px flex-1 bg-[#c6a15b]/25"></span>
      </div>
    </div>

    <section class="relative left-1/2 right-1/2 -mx-[50vw] w-screen mt-6">
      <div id="exp-track" class="flex gap-4 overflow-x-auto snap-x snap-mandatory scroll-smooth no-scrollbar px-[7vw] lg:px-[12vw]">
        {EXPERIENCES.map((ex, i) => (
          <article
            class="exp-slide group relative snap-center shrink-0 min-w-[86vw] sm:min-w-[68vw] lg:min-w-[54vw] rounded-3xl overflow-hidden scale-[0.96] opacity-80 transition-[transform,opacity] duration-[600ms] ease-out"
            data-index={i}
            style="height:clamp(460px,74vh,660px)"
          >
            <img src={ex.img} alt={ex.label} loading={i === 0 ? 'eager' : 'lazy'} class="absolute inset-0 h-full w-full object-cover" />
            <span class="absolute inset-0 bg-gradient-to-t from-[#17130d]/85 via-[#17130d]/25 to-transparent"></span>
            <span class="absolute inset-0 bg-[#cc6600]/10 mix-blend-multiply"></span>

            <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8">
              <p class="text-[11px] uppercase tracking-[0.2em] text-[#c6a15b] mb-1">{String(i + 1).padStart(2, '0')} · {ex.kicker}</p>
              <h3 class="exp-title font-serif text-4xl sm:text-5xl text-[#fdf8ef] leading-none">{ex.label}</h3>
              <p class="mt-2 font-serif italic text-lg text-[#fdf8ef]/80">{ex.desc}</p>
              <div class="mt-4 flex flex-wrap items-center gap-3">
                <button type="button" data-filter={ex.filter} class="exp-menus-open inline-block rounded-full bg-[#fdf8ef]/10 backdrop-blur-sm border border-[#c6a15b]/50 px-4 py-1.5 text-[13px] text-[#fdf8ef] hover:bg-[#fdf8ef]/20 transition-colors cursor-pointer">{ex.price}</button>
                <a href={ex.link} class="inline-flex items-center gap-1.5 rounded-full bg-[#c6a15b] px-4 py-1.5 text-[13px] font-semibold text-[#17130d] hover:bg-[#d4b06a] transition-colors">{ex.linkLabel} →</a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- controls -->
      <div class="max-w-3xl mx-auto px-5 mt-4 flex items-center justify-between">
        <p id="exp-echo" class="text-sm text-gray-500">Scroll to explore →</p>
        <div class="flex items-center gap-2">
          <button type="button" id="exp-prev" aria-label="Previous" class="hidden sm:flex w-9 h-9 items-center justify-center rounded-full border border-[#c6a15b]/40 text-[#17130d] hover:bg-[#17130d] hover:text-white transition-colors">‹</button>
          <button type="button" id="exp-next" aria-label="Next" class="hidden sm:flex w-9 h-9 items-center justify-center rounded-full border border-[#c6a15b]/40 text-[#17130d] hover:bg-[#17130d] hover:text-white transition-colors">›</button>
        </div>
      </div>
      <div id="exp-dots" class="flex justify-center gap-2 mt-3"></div>
    </section>

    <!-- In-page menus modal (opened from the experience gallery chips) -->
    <div id="menus-modal" class="fixed inset-0 z-[70] hidden items-center justify-center p-4">
      <div id="menus-backdrop" class="absolute inset-0 bg-[#17130d]/70 backdrop-blur-sm"></div>
      <div id="menus-panel" class="relative max-h-[88vh] w-full max-w-3xl overflow-y-auto rounded-3xl bg-[#fdfbf7] p-6 sm:p-8 shadow-2xl">
        <div class="flex items-center justify-between mb-5">
          <h3 class="font-serif text-2xl text-[#17130d]">The menus</h3>
          <button type="button" id="menus-close" aria-label="Close" class="w-9 h-9 rounded-full bg-[#17130d] text-[#fdf8ef] hover:bg-black transition-colors">✕</button>
        </div>
        <div class="relative">
          <div id="menus-track" class="flex gap-4 overflow-x-auto snap-x snap-mandatory no-scrollbar pb-2 scroll-smooth"></div>
          <button type="button" id="mm-prev" aria-label="Previous menu" class="hidden sm:flex absolute -left-3 top-1/2 -translate-y-1/2 w-9 h-9 items-center justify-center rounded-full bg-[#17130d] text-[#fdf8ef] shadow-lg hover:bg-black transition-colors">←</button>
          <button type="button" id="mm-next" aria-label="Next menu" class="hidden sm:flex absolute -right-3 top-1/2 -translate-y-1/2 w-9 h-9 items-center justify-center rounded-full bg-[#17130d] text-[#fdf8ef] shadow-lg hover:bg-black transition-colors">→</button>
        </div>
        <p class="mt-3 text-center text-[11px] text-gray-400 sm:hidden">Swipe to browse</p>
        <p class="mt-5 text-center text-[11px] text-gray-400">+ chef service €600 per event · prices are indicative</p>
      </div>
    </div>

    <form id="request-form" novalidate>
      <!-- CHAPTER 02 — I DETTAGLI -->
      <div id="details" class="max-w-2xl mx-auto px-5 mt-16 scroll-mt-24">
        <div class="flex items-center gap-4 mb-8">
          <span class="font-serif text-2xl text-[#c6a15b]">II</span>
          <span class="text-xs uppercase tracking-[0.2em] text-[#17130d]/70">The details</span>
          <span class="h-px flex-1 bg-[#c6a15b]/25"></span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div>
            <label for="customer_name" class="block text-xs uppercase tracking-wider text-gray-500 mb-1">Full name</label>
            <input id="customer_name" name="customer_name" type="text" required
              class="w-full bg-transparent border-0 border-b border-gray-300 px-0 py-2.5 text-lg focus:border-[#c6a15b] focus:ring-0 placeholder:text-gray-400" placeholder="First name Surname" />
          </div>
          <div>
            <label for="phone_local" class="block text-xs uppercase tracking-wider text-gray-500 mb-1">Phone</label>
            <div class="flex items-end gap-2 border-b border-gray-300 focus-within:border-[#c6a15b]">
              <!-- Country-code selector -->
              <div class="relative shrink-0">
                <button type="button" id="phone-cc-btn" aria-haspopup="listbox" aria-expanded="false"
                  class="flex items-center gap-1.5 py-2.5 text-lg text-[#17130d] focus:outline-none">
                  <span id="phone-cc-flag">🇮🇹</span>
                  <span id="phone-cc-dial" class="tabular-nums">+39</span>
                  <svg class="w-4 h-4 text-[#c6a15b]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="m6 9 6 6 6-6"/></svg>
                </button>
                <div id="phone-cc-pop" data-open="false"
                  class="absolute z-30 mt-2 left-0 w-72 rounded-2xl border border-[#c6a15b]/30 bg-[#fffef9] shadow-xl origin-top transition data-[open=false]:opacity-0 data-[open=false]:translate-y-1 data-[open=false]:pointer-events-none">
                  <div class="p-2 border-b border-[#c6a15b]/15">
                    <input id="phone-cc-search" type="text" autocomplete="off" placeholder="Search country…"
                      class="w-full bg-transparent border-0 border-b border-gray-200 px-1 py-1.5 text-sm focus:border-[#c6a15b] focus:ring-0 placeholder:text-gray-400" />
                  </div>
                  <ul id="phone-cc-list" role="listbox" class="max-h-60 overflow-y-auto py-1 text-sm">
                    {COUNTRIES.map((c) => (
                      <li>
                        <button type="button" class="phone-cc-opt w-full flex items-center gap-2.5 px-3 py-2 text-left hover:bg-[#faf0dd]"
                          data-dial={c.dial_code} data-flag={c.flag} data-name={c.name}>
                          <span>{c.flag}</span>
                          <span class="flex-1 truncate text-[#17130d]">{c.name}</span>
                          <span class="text-gray-400 tabular-nums">{c.dial_code}</span>
                        </button>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
              <!-- Local number -->
              <input id="phone_local" type="tel" inputmode="tel" required
                class="flex-1 min-w-0 bg-transparent border-0 px-0 py-2.5 text-lg focus:ring-0 placeholder:text-gray-400" placeholder="333 1234567" />
            </div>
            <!-- Full international number, kept in sync; read by the submit code. -->
            <input id="customer_phone" name="customer_phone" type="hidden" />
            <p id="phone-error" class="mt-1 text-xs text-red-500 hidden">Please enter 6–15 digits.</p>
          </div>
        </div>

        <div class="mt-6">
          <label for="customer_email" class="block text-xs uppercase tracking-wider text-gray-500 mb-1">Email</label>
          <input id="customer_email" name="customer_email" type="email" required
            class="w-full bg-transparent border-0 border-b border-gray-300 px-0 py-2.5 text-lg focus:border-[#c6a15b] focus:ring-0 placeholder:text-gray-400" placeholder="you@example.com" />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-6">
          <div>
            <label class="block text-xs uppercase tracking-wider text-gray-500 mb-1">Guests</label>
            <div class="flex items-center gap-4 py-1.5 border-b border-gray-300">
              <button type="button" id="g-minus" aria-label="Minus" class="w-11 h-11 rounded-full border border-[#c6a15b]/40 text-2xl leading-none text-[#17130d] hover:bg-[#17130d] hover:text-white transition-colors">−</button>
              <input id="num_guests" name="num_guests" type="number" min="1" max="200" value="2" required
                class="w-16 text-center bg-transparent border-0 p-0 text-xl font-serif focus:ring-0" />
              <button type="button" id="g-plus" aria-label="Plus" class="w-11 h-11 rounded-full border border-[#c6a15b]/40 text-2xl leading-none text-[#17130d] hover:bg-[#17130d] hover:text-white transition-colors">+</button>
            </div>
          </div>
          <div class="relative">
            <label for="date-display" class="block text-xs uppercase tracking-wider text-gray-500 mb-1">When</label>
            <button type="button" id="date-display" aria-haspopup="dialog" aria-expanded="false"
              class="w-full flex items-center justify-between bg-transparent border-0 border-b border-gray-300 px-0 py-2.5 text-lg text-left focus:border-[#c6a15b] focus:outline-none">
              <span id="date-label" class="text-gray-400">Choose a date</span>
              <svg class="w-5 h-5 text-[#c6a15b]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            </button>
            <input type="hidden" id="start_date" name="start_date" />
            <input type="hidden" id="end_date" name="end_date" />
            <div id="cal-popover" data-open="false" class="absolute z-30 mt-2 right-0 w-80 rounded-2xl border border-[#c6a15b]/30 bg-[#fffef9] shadow-xl p-4 origin-top transition data-[open=false]:opacity-0 data-[open=false]:translate-y-1 data-[open=false]:pointer-events-none">
              <div class="flex items-center justify-between mb-3">
                <button type="button" id="cal-prev" aria-label="Previous month" class="w-9 h-9 rounded-full text-[#17130d] hover:text-[#c6a15b] disabled:opacity-30 disabled:hover:text-[#17130d]">‹</button>
                <span id="cal-title" class="font-serif text-lg"></span>
                <button type="button" id="cal-next" aria-label="Next month" class="w-9 h-9 rounded-full text-[#17130d] hover:text-[#c6a15b]">›</button>
              </div>
              <div class="grid grid-cols-7 gap-1 text-center text-[11px] uppercase tracking-wider text-[#c6a15b] mb-1">
                <span>M</span><span>T</span><span>W</span><span>T</span><span>F</span><span>S</span><span>S</span>
              </div>
              <div id="cal-grid" class="grid grid-cols-7 gap-1" role="grid"></div>
              <div class="mt-2 flex items-center justify-between gap-2">
                <p class="text-[11px] text-gray-400">Pick one day, or tap a later day for more.</p>
                <button type="button" id="cal-done" class="shrink-0 text-xs font-semibold text-[#17130d] rounded-full border border-[#c6a15b]/40 px-3 py-1 hover:bg-[#faf0dd]">Done</button>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-6">
          <label for="meal_type" class="block text-xs uppercase tracking-wider text-gray-500 mb-1">Type of meal</label>
          <select id="meal_type" name="meal_type"
            class="w-full bg-transparent border-0 border-b border-gray-300 px-0 py-2.5 text-lg focus:border-[#c6a15b] focus:ring-0">
            <option value="50" data-name="Dinner" selected>Dinner</option>
            <option value="40" data-name="Lunch">Lunch</option>
            <option value="25" data-name="Breakfast">Breakfast</option>
            <option value="45" data-name="Buffet">Buffet</option>
          </select>
        </div>

        <div class="mt-5 rounded-2xl border border-[#c6a15b]/30 bg-[#fbf7ef] px-5 py-4">
          <p class="text-[11px] uppercase tracking-[0.2em] text-[#a07b35]">Indicative price</p>
          <p class="mt-1 leading-tight">
            <span id="estimate-amount" class="font-serif text-2xl text-[#17130d]">—</span>
            <span class="text-sm text-gray-500">· final quote by Chef Nino</span>
          </p>
          <p id="estimate-breakdown" class="mt-1 text-xs text-gray-400"></p>
          <p class="mt-2 text-[11px] text-gray-400">Estimate only — the final quote can be lower or higher, depending on your wishes. No payment now.</p>
        </div>

        <div class="mt-6">
          <label for="city" class="block text-xs uppercase tracking-wider text-gray-500 mb-1">City</label>
          <input id="city" name="city" type="text" required
            class="w-full bg-transparent border-0 border-b border-gray-300 px-0 py-2.5 text-lg focus:border-[#c6a15b] focus:ring-0 placeholder:text-gray-400" placeholder="City" />
        </div>

        <div class="mt-6">
          <label for="event_address" class="block text-xs uppercase tracking-wider text-gray-500 mb-1">Address</label>
          <input id="event_address" name="event_address" type="text" required
            class="w-full bg-transparent border-0 border-b border-gray-300 px-0 py-2.5 text-lg focus:border-[#c6a15b] focus:ring-0 placeholder:text-gray-400" placeholder="Where should the event take place? Street and number" />
        </div>
      </div>

      <!-- divider -->
      <div class="max-w-2xl mx-auto px-5 flex items-center gap-4 my-14">
        <span class="h-px flex-1 bg-[#c6a15b]/30"></span>
        <span class="font-serif text-[#c6a15b]">✦</span>
        <span class="h-px flex-1 bg-[#c6a15b]/30"></span>
      </div>

      <!-- CHAPTER 03 — YOUR IDEA -->
      <div class="max-w-2xl mx-auto px-5">
        <div class="flex items-center gap-4 mb-8">
          <span class="font-serif text-2xl text-[#c6a15b]">III</span>
          <span class="text-xs uppercase tracking-[0.2em] text-[#17130d]/70">Your idea</span>
          <span class="h-px flex-1 bg-[#c6a15b]/25"></span>
        </div>

        <textarea id="event_details" name="event_details" rows="5" required
          class="w-full rounded-3xl bg-white border border-[#c6a15b]/25 shadow-lg px-5 py-4 text-base focus:outline-none focus:ring-2 focus:ring-gold-500 placeholder:text-gray-400"
          placeholder="Tell Chef Nino about your evening — the occasion, the flavours you love, any allergies or dietary needs, and anything that would make it yours. You will receive a personal proposal with menu and price."></textarea>

        <!-- honeypot -->
        <input type="text" name="company_website" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

        <!-- Welcome gift — first-booking 10%, applied by the chef directly in the
             proposal (concierge model: no promo codes anywhere). -->
        <div class="mt-6 rounded-2xl border border-[#c6a15b]/40 bg-[#fbf7ef] px-5 py-4 flex items-start gap-3">
          <span class="mt-0.5 shrink-0 text-[#c6a15b] font-serif text-lg leading-none">✦</span>
          <div>
            <p class="text-[11px] uppercase tracking-[0.2em] text-[#a07b35]">Your welcome gift</p>
            <p class="mt-1.5 text-sm leading-relaxed text-[#575147]">
              <span class="font-serif text-[#17130d]">10% off your first booking</span> —
              no codes needed: Chef Nino applies it directly in your proposal. Valid once.
            </p>
          </div>
        </div>

        <label class="flex items-start gap-2 text-xs text-gray-500 mt-6">
          <input id="consent" type="checkbox" required class="mt-0.5 h-4 w-4 rounded border-gray-300 text-gold-600 focus:ring-gold-500" />
          <span>I consent to my data being processed so that I can be contacted about this request.</span>
        </label>

        <button id="request-submit" type="button"
          class="mt-5 w-full inline-flex items-center justify-center gap-2 rounded-2xl bg-[#17130d] text-[#fdf8ef] py-4 text-sm font-serif tracking-wide hover:bg-black active:scale-[0.99] transition-all disabled:opacity-60">
          <span class="text-[#c6a15b]">✦</span>
          <span id="request-submit-label">Send your request to Chef Nino</span>
          <span id="request-spinner" class="hidden h-4 w-4 border-2 border-[#fdf8ef] border-t-transparent rounded-full animate-spin"></span>
        </button>
        <p id="request-error" class="mt-2 text-sm text-red-500 hidden"></p>
        <p class="mt-3 text-center text-xs text-gray-400">No payment now. Chef Nino will write to you with the proposal and the price.</p>
        <div class="mt-4 flex flex-wrap items-center justify-center gap-x-5 gap-y-1 text-[11px] uppercase tracking-[0.15em] text-[#a07b35]">
          <span>Reply within 24h</span><span class="text-[#c6a15b]/50">&middot;</span><span>No payment now</span><span class="text-[#c6a15b]/50">&middot;</span><span>Your details stay private</span>
        </div>
      </div>

      <!-- success -->
      <div id="request-success" class="hidden max-w-2xl mx-auto px-5 py-16 text-center">
        <div class="flex justify-center">
          <span class="flex h-16 w-16 items-center justify-center rounded-full bg-[#c6a15b]/15 text-[#c6a15b] text-2xl font-serif">✦</span>
        </div>
        <h2 class="mt-5 font-serif text-3xl">Request sent</h2>
        <p class="mt-2 text-gray-500">Thank you — Chef Nino will write to you very shortly with a bespoke proposal and price.</p>
        <a href="/" class="mt-6 inline-block rounded-full border border-[#c6a15b]/40 px-6 py-2.5 text-sm font-semibold hover:bg-white">Back to home</a>
      </div>
    </form>

    <div class="h-20"></div>
  </main>
</Layout>

<style>
  .no-scrollbar { scrollbar-width: none; }
  .no-scrollbar::-webkit-scrollbar { display: none; }

  /* On phones, render the calendar and country-code popovers as full-width
     bottom sheets so they never clip at the screen edge. */
  @media (max-width: 480px) {
    #cal-popover[data-open="true"],
    #phone-cc-pop[data-open="true"] {
      position: fixed;
      left: 0; right: 0; bottom: 0; top: auto;
      width: 100%;
      margin: 0;
      border-radius: 1.25rem 1.25rem 0 0;
      max-height: 82vh;
      overflow-y: auto;
      z-index: 80;
      padding-bottom: calc(env(safe-area-inset-bottom) + 20px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation: none !important; transition: none !important; }
    .exp-slide { transform: none !important; opacity: 1 !important; }
  }
</style>

<!-- Availability is not managed in-site: the calendar is a simple preferred-date picker. -->

<script>
  // ===== READING PROGRESS BAR =====
  (() => {
    const fill = document.getElementById('progress-fill');
    if (!fill) return;
    const update = () => {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      const pct = max > 0 ? Math.min(100, Math.max(0, (window.scrollY / max) * 100)) : 0;
      fill.style.width = pct + '%';
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
  })();

  // ===== SLIDESHOW (visual gallery — inspiration only, no selection) =====
  (() => {
    const track = document.getElementById('exp-track');
    const slides = Array.from(document.querySelectorAll('.exp-slide')) as HTMLElement[];
    const dotsWrap = document.getElementById('exp-dots');
    if (!track || !slides.length) return;

    // dots
    slides.forEach((_, i) => {
      const d = document.createElement('button');
      d.type = 'button';
      d.className = 'h-1 w-6 rounded-full bg-[#c6a15b]/25 transition-colors';
      d.addEventListener('click', () => slides[i].scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' }));
      dotsWrap?.appendChild(d);
    });
    const dots = Array.from(dotsWrap?.children || []) as HTMLElement[];

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        const el = e.target as HTMLElement;
        const i = slides.indexOf(el);
        if (e.isIntersecting && e.intersectionRatio >= 0.6) {
          slides.forEach((s) => s.classList.remove('is-active', 'scale-100', 'opacity-100'));
          el.classList.add('is-active', 'scale-100', 'opacity-100');
          dots.forEach((d, di) => d.classList.toggle('bg-[#c6a15b]', di === i));
          dots.forEach((d, di) => d.classList.toggle('bg-[#c6a15b]/25', di !== i));
        }
      });
    }, { root: track, threshold: 0.6 });
    slides.forEach((s) => io.observe(s));

    const step = () => (slides[0]?.getBoundingClientRect().width || 320) + 20;
    document.getElementById('exp-prev')?.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
    document.getElementById('exp-next')?.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
  })();

  // ===== GUESTS STEPPER =====
  (() => {
    const inp = document.getElementById('num_guests') as HTMLInputElement | null;
    if (!inp) return;
    const clamp = (n: number) => Math.max(1, Math.min(200, n));
    document.getElementById('g-minus')?.addEventListener('click', () => { inp.value = String(clamp((parseInt(inp.value, 10) || 1) - 1)); });
    document.getElementById('g-plus')?.addEventListener('click', () => { inp.value = String(clamp((parseInt(inp.value, 10) || 1) + 1)); });
  })();

  // ===== INDICATIVE PRICE ESTIMATE =====
  // Mirrors the /owner calculator: chef day fee + per-guest cover × guests.
  // Purely informational on the request form — the customer doesn't pay here,
  // it just sets expectations so they complete the request. Final quote is the
  // owner's, sent later. Chef base uses the standard full-day rate.
  (async () => {
    const guestsInp = document.getElementById('num_guests') as HTMLInputElement | null;
    const mealSel = document.getElementById('meal_type') as HTMLSelectElement | null;
    const amountEl = document.getElementById('estimate-amount');
    const breakdownEl = document.getElementById('estimate-breakdown');
    const ta = document.getElementById('event_details') as HTMLTextAreaElement | null;
    if (!guestsInp || !mealSel || !amountEl || !breakdownEl) return;

    const { TASTING_MENUS, CHEF_SERVICE_EUR } = await import('../lib/tasting-menus');
    const MENU_RE = new RegExp("^Menu I'd love:[^\\n]*\\n*");
    const MEAL_VALUE: Record<string, string> = { breakfast: '25', lunch: '40', dinner: '50', buffet: '45' };
    let chosenMenu: { name: string; price: number; extra: number; extraLabel: string; minGuests: number } | null = null;

    const fmtEur = (n: number) => '€' + n.toLocaleString('it-IT');
    function recompute() {
      const guests = Math.max(1, Math.min(200, parseInt(guestsInp!.value, 10) || 1));
      if (chosenMenu) {
        const effGuests = Math.max(guests, chosenMenu.minGuests || 1);
        amountEl!.textContent = fmtEur(CHEF_SERVICE_EUR + chosenMenu.extra + chosenMenu.price * effGuests);
        const extraTxt = chosenMenu.extra ? ` + ${chosenMenu.extraLabel} ${fmtEur(chosenMenu.extra)}` : '';
        const minTxt = chosenMenu.minGuests && guests < chosenMenu.minGuests ? ` (minimum ${chosenMenu.minGuests} guests)` : '';
        breakdownEl!.textContent = `Chef service ${fmtEur(CHEF_SERVICE_EUR)}${extraTxt} + Menu ${chosenMenu.name} ${fmtEur(chosenMenu.price)} × ${effGuests} guests${minTxt}`;
        return;
      }
      const rate = Number(mealSel!.value) || 0;
      const mealName = mealSel!.options[mealSel!.selectedIndex]?.dataset.name || 'Meal';
      amountEl!.textContent = `from ${fmtEur(CHEF_SERVICE_EUR + rate * guests)}`;
      breakdownEl!.textContent = `Chef service ${fmtEur(CHEF_SERVICE_EUR)} + ${mealName} from ${fmtEur(rate)} per person × ${guests} guests`;
    }

    // Select a tasting menu: prefill the idea, sync meal type, recompute — no reload.
    function applyMenu(rawName: string, scroll: boolean) {
      const name = rawName.replace(/[<>]/g, '').replace(/\s+/g, ' ').trim().slice(0, 60);
      const hit = TASTING_MENUS.find((m) => m.name.toLowerCase() === name.toLowerCase());
      if (!hit) return;
      chosenMenu = { name: hit.name, price: hit.price, extra: hit.serviceExtraEur || 0, extraLabel: hit.serviceExtraLabel || '', minGuests: hit.minGuests || 0 };
      mealSel!.value = MEAL_VALUE[hit.meal || 'dinner'] || '50';
      if (ta && !ta.disabled) {
        const rest = ta.value.replace(MENU_RE, '');
        ta.value = `Menu I'd love: ${hit.name}

${rest}`;
      }
      recompute();
      if (scroll) document.getElementById('details')?.scrollIntoView({ behavior: 'smooth' });
    }

    ['change', 'input'].forEach((ev) => {
      guestsInp.addEventListener(ev, recompute);
      mealSel.addEventListener(ev, () => { chosenMenu = null; recompute(); });
    });
    // The +/- steppers set the value directly without firing events, so recompute on their click too.
    document.getElementById('g-minus')?.addEventListener('click', recompute);
    document.getElementById('g-plus')?.addEventListener('click', recompute);

    // Arriving with ?menu= (e.g. from La Carta): prefill without scrolling.
    const rawMenu = new URLSearchParams(location.search).get('menu');
    if (rawMenu) applyMenu(rawMenu, false);

    // Same-page menu links (experience gallery): fill + scroll, no reload.
    document.querySelectorAll<HTMLAnchorElement>('a[href^="/richiesta?menu="]').forEach((a) => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const url = new URL(a.getAttribute('href')!, location.origin);
        history.replaceState(null, '', url.pathname + url.search);
        applyMenu(url.searchParams.get('menu') || '', true);
      });
    });

    // In-page menus modal: gallery chips open it, "Request" rows fill the form.
    const modal = document.getElementById('menus-modal');
    const trackEl = document.getElementById('menus-track');
    function closeModal() { modal?.classList.add('hidden'); modal?.classList.remove('flex'); }
    function openModal(filter: string) {
      if (!modal || !trackEl) return;
      const byName = filter.split(',').map((s) => s.trim());
      const isNameFilter = TASTING_MENUS.some((m) => byName.includes(m.name));
      const menus = filter === 'all'
        ? TASTING_MENUS
        : isNameFilter
          ? TASTING_MENUS.filter((m) => byName.includes(m.name))
          : TASTING_MENUS.filter((m) => (m.meal || 'dinner') === filter);
      trackEl.innerHTML = '';
      const single = menus.length === 1;
      const panel = document.getElementById('menus-panel');
      panel?.classList.toggle('max-w-3xl', !single);
      panel?.classList.toggle('max-w-xl', single);
      ['mm-prev', 'mm-next'].forEach((id) => {
        const b = document.getElementById(id);
        if (b) b.style.display = single ? 'none' : '';
      });
      const safe = (s: string) => s.replace(/[<>&]/g, '');
      menus.forEach((m) => {
        const card = document.createElement('article');
        card.className = single
          ? 'shrink-0 w-full rounded-3xl border border-[#e0cfa6] bg-white px-6 py-7 text-center'
          : 'snap-center shrink-0 w-[86%] sm:w-[400px] rounded-3xl border border-[#e0cfa6] bg-white px-6 py-7 text-center';
        const courses = m.courses.map((c) =>
          `<li class="mb-3"><p class="text-[10px] uppercase tracking-[0.25em] text-[#a07b35]">${safe(c.course)}</p><p class="font-serif text-[16px] leading-snug text-[#17130d]">${safe(c.it)}</p><p class="text-[11px] italic text-[#8a8174]">${safe(c.en)}</p></li>`
        ).join('');
        const extra = m.serviceExtraEur ? ` · ${safe(m.serviceExtraLabel || 'service')} €${m.serviceExtraEur}` : '';
        const minG = m.minGuests ? ` · min ${m.minGuests} guests` : '';
        card.innerHTML = `
          <h4 class="font-serif text-2xl text-[#17130d]">${safe(m.name)}</h4>
          <p class="font-serif italic text-sm text-[#8a6c2f]">${safe(m.tag)}</p>
          <p class="mt-2 font-serif text-xl text-[#17130d]"><span class="text-[#a07b35] font-semibold">€${m.price}</span> <span class="text-sm text-[#8a8174]">per person</span></p>
          <p class="text-[11px] text-[#8a8174]">+ chef service €600${extra}${minG}</p>
          <div class="mx-auto my-4 h-px w-10 bg-[#c6a15b]"></div>
          <ul>${courses}</ul>`;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'mt-4 inline-flex items-center gap-2 rounded-full bg-[#c6a15b] px-6 py-2.5 text-[14px] font-semibold text-[#17130d] hover:bg-[#d4b06a] transition-colors';
        btn.textContent = 'Request this menu →';
        btn.addEventListener('click', () => { closeModal(); applyMenu(m.name, true); });
        card.appendChild(btn);
        trackEl.appendChild(card);
      });
      trackEl.scrollLeft = 0;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }
    document.querySelectorAll<HTMLButtonElement>('.exp-menus-open').forEach((b) =>
      b.addEventListener('click', () => openModal(b.dataset.filter || 'all')));
    document.getElementById('menus-close')?.addEventListener('click', closeModal);
    const mmStep = () => (trackEl?.firstElementChild ? (trackEl.firstElementChild as HTMLElement).offsetWidth + 16 : 400);
    document.getElementById('mm-prev')?.addEventListener('click', () => trackEl?.scrollBy({ left: -mmStep(), behavior: 'smooth' }));
    document.getElementById('mm-next')?.addEventListener('click', () => trackEl?.scrollBy({ left: mmStep(), behavior: 'smooth' }));
    document.getElementById('menus-backdrop')?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    recompute();
  })();

  // ===== PHONE COUNTRY-CODE SELECTOR =====
  (() => {
    const btn = document.getElementById('phone-cc-btn');
    const pop = document.getElementById('phone-cc-pop');
    const flagEl = document.getElementById('phone-cc-flag');
    const dialEl = document.getElementById('phone-cc-dial');
    const search = document.getElementById('phone-cc-search') as HTMLInputElement | null;
    const localInp = document.getElementById('phone_local') as HTMLInputElement | null;
    const hidden = document.getElementById('customer_phone') as HTMLInputElement | null;
    const errEl = document.getElementById('phone-error');
    const opts = Array.from(document.querySelectorAll('.phone-cc-opt')) as HTMLButtonElement[];
    if (!btn || !pop || !flagEl || !dialEl || !localInp || !hidden) return;

    let dial = '+39';

    function syncHidden() {
      const digits = localInp!.value.replace(/\D/g, '');
      hidden!.value = digits ? `${dial} ${digits}` : '';
    }

    function validate() {
      const digits = localInp!.value.replace(/\D/g, '');
      const ok = digits.length >= 6 && digits.length <= 15;
      if (errEl) errEl.classList.toggle('hidden', ok || digits.length === 0);
      return ok;
    }

    function openPop() { pop!.dataset.open = 'true'; btn!.setAttribute('aria-expanded', 'true'); if (search) { search.value = ''; filter(''); search.focus(); } }
    function closePop() { pop!.dataset.open = 'false'; btn!.setAttribute('aria-expanded', 'false'); }

    function filter(q: string) {
      const needle = q.trim().toLowerCase();
      opts.forEach((o) => {
        const name = (o.dataset.name || '').toLowerCase();
        const d = (o.dataset.dial || '').toLowerCase();
        const li = o.parentElement as HTMLElement;
        li.style.display = !needle || name.includes(needle) || d.includes(needle) ? '' : 'none';
      });
    }

    btn.addEventListener('click', () => { pop!.dataset.open === 'true' ? closePop() : openPop(); });
    search?.addEventListener('input', () => filter(search.value));
    opts.forEach((o) => o.addEventListener('click', () => {
      dial = o.dataset.dial || '+39';
      flagEl!.textContent = o.dataset.flag || '';
      dialEl!.textContent = dial;
      syncHidden();
      closePop();
      localInp!.focus();
    }));

    localInp.addEventListener('input', () => { syncHidden(); validate(); });
    localInp.addEventListener('blur', validate);

    document.addEventListener('click', (e) => { if (!pop.contains(e.target as Node) && !btn.contains(e.target as Node)) closePop(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePop(); });

    syncHidden();
  })();

  // ===== CUSTOM CALENDAR (single day OR a date range; no in-site availability) =====
  (() => {
    const trigger = document.getElementById('date-display');
    const labelEl = document.getElementById('date-label');
    const startHidden = document.getElementById('start_date') as HTMLInputElement | null;
    const endHidden = document.getElementById('end_date') as HTMLInputElement | null;
    const pop = document.getElementById('cal-popover');
    const title = document.getElementById('cal-title');
    const grid = document.getElementById('cal-grid');
    const prev = document.getElementById('cal-prev') as HTMLButtonElement | null;
    const next = document.getElementById('cal-next');
    const doneBtn = document.getElementById('cal-done');
    if (!trigger || !pop || !grid || !title || !startHidden || !labelEl) return;

    const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const now = new Date();
    const todayY = now.getFullYear(), todayM = now.getMonth(), todayD = now.getDate();
    let viewY = todayY, viewM = todayM;
    let startISO = '';
    let endISO = '';
    let phase: 'idle' | 'open' | 'done' = 'idle';

    const iso = (y: number, m: number, d: number) => `${y}-${String(m + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
    const atStart = () => viewY === todayY && viewM === todayM;
    const fmt = (s: string) => {
      const [y, m, d] = s.split('-').map(Number);
      return new Date(y, m - 1, d).toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
    };

    function syncLabel() {
      if (!startISO) { labelEl!.textContent = 'Choose a date'; labelEl!.classList.add('text-gray-400'); return; }
      labelEl!.classList.remove('text-gray-400');
      labelEl!.textContent = (!endISO || endISO === startISO) ? fmt(startISO) : `${fmt(startISO)} → ${fmt(endISO)}`;
    }

    function commit() {
      startHidden!.value = startISO || '';
      if (endHidden) endHidden.value = endISO || startISO || '';
      syncLabel();
    }

    function pick(thisISO: string) {
      if (phase === 'idle' || phase === 'done') {
        startISO = thisISO; endISO = thisISO; phase = 'open';   // 1st tap = single day
        commit(); render();
      } else if (thisISO > startISO) {
        endISO = thisISO; phase = 'done';                       // 2nd later tap = range → close
        commit(); render(); close();
      } else {
        startISO = thisISO; endISO = thisISO;                   // same/earlier → restart, stay open
        commit(); render();
      }
    }

    function render() {
      title!.textContent = `${MONTHS[viewM]} ${viewY}`;
      if (prev) prev.disabled = atStart();
      grid!.innerHTML = '';
      const first = new Date(viewY, viewM, 1).getDay(); // 0=Sun
      const offset = (first + 6) % 7; // Monday-first
      const days = new Date(viewY, viewM + 1, 0).getDate();
      for (let i = 0; i < offset; i++) grid!.appendChild(document.createElement('span'));
      for (let d = 1; d <= days; d++) {
        const cell = document.createElement('button');
        cell.type = 'button';
        cell.textContent = String(d);
        const past = viewY === todayY && viewM === todayM && d < todayD;
        const isToday = viewY === todayY && viewM === todayM && d === todayD;
        const thisISO = iso(viewY, viewM, d);
        const inRange = !!startISO && !!endISO && thisISO >= startISO && thisISO <= endISO;
        const isEndpoint = thisISO === startISO || thisISO === endISO;
        cell.className = 'h-10 w-10 text-sm flex items-center justify-center transition-colors';
        if (past) {
          cell.className += ' rounded-full text-gray-300 cursor-default';
          cell.disabled = true;
        } else {
          if (isEndpoint) cell.className += ' rounded-full bg-[#17130d] text-[#fdf8ef]';
          else if (inRange) cell.className += ' bg-[#f0e2c4] text-[#17130d]';
          else cell.className += ' rounded-full hover:bg-[#faf0dd]' + (isToday ? ' ring-1 ring-gold-500' : '');
          cell.addEventListener('click', () => pick(thisISO));
        }
        grid!.appendChild(cell);
      }
    }
    function open() { phase = 'done'; pop!.dataset.open = 'true'; trigger!.setAttribute('aria-expanded', 'true'); render(); }
    function close() { pop!.dataset.open = 'false'; trigger!.setAttribute('aria-expanded', 'false'); }

    trigger.addEventListener('click', () => { pop!.dataset.open === 'true' ? close() : open(); });
    prev?.addEventListener('click', () => { if (atStart()) return; viewM--; if (viewM < 0) { viewM = 11; viewY--; } render(); });
    next?.addEventListener('click', () => { viewM++; if (viewM > 11) { viewM = 0; viewY++; } render(); });
    doneBtn?.addEventListener('click', () => close());
    document.addEventListener('click', (e) => { if (!pop.contains(e.target as Node) && !trigger.contains(e.target as Node)) close(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    render();
  })();

  // ===== SUBMIT (request form -> /api/request-booking) =====
  (() => {
    const form = document.getElementById('request-form');
    const submitBtn = document.getElementById('request-submit') as HTMLButtonElement | null;
    const spinner = document.getElementById('request-spinner');
    const errorBox = document.getElementById('request-error');
    const successBox = document.getElementById('request-success');
    const eventDetails = document.getElementById('event_details') as HTMLTextAreaElement | null;
    if (!form || !submitBtn) return;

    let submitted = false;

    function showSuccess() {
      submitted = true;
      // The /menu selection has served its purpose — don't re-prefill next time.
      try { sessionStorage.removeItem('selectedDishes'); } catch { /* ignore */ }
      form!.querySelectorAll('input,textarea,button').forEach((el) => ((el as HTMLButtonElement).disabled = true));
      // hide everything except the success block
      Array.from((form as HTMLElement).children).forEach((c) => { if (c.id !== 'request-success') (c as HTMLElement).style.display = 'none'; });
      successBox?.classList.remove('hidden');
      successBox?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    function showErr(m: string) { if (errorBox) { errorBox.textContent = m; errorBox.classList.remove('hidden'); } }

    submitBtn.addEventListener('click', async () => {
      if (submitted) return;
      errorBox?.classList.add('hidden');
      const v = (id: string) => (document.getElementById(id) as HTMLInputElement | null)?.value.trim() || '';
      const consent = (document.getElementById('consent') as HTMLInputElement | null)?.checked;
      if (!v('customer_name')) return showErr('Please enter your full name.');
      if (!/^\S+@\S+\.\S+$/.test(v('customer_email'))) return showErr('Please enter a valid email.');
      if (v('customer_phone').replace(/\D/g, '').length < 6) return showErr('Please enter a valid phone number.');
      if (!v('num_guests')) return showErr('Please enter the number of guests.');
      if (!v('start_date')) return showErr('Please choose a date.');
      if (!v('city')) return showErr('Please enter the city.');
      if (!v('event_address')) return showErr('Please enter the address of the event.');
      if (!v('event_details')) return showErr('Please describe the evening you have in mind.');
      if (!consent) return showErr('Please tick the consent box to send.');

      // Their idea (free text) — fold in the selected meal type so it actually
      // reaches the owner (there is no dedicated meal_type column; it travels with
      // the idea text in dietary_preferences). Previously the choice was discarded.
      const mealSel = document.getElementById('meal_type') as HTMLSelectElement | null;
      const mealName = mealSel?.options[mealSel.selectedIndex]?.dataset.name || '';
      const idea = eventDetails?.value.trim() || '';
      const details = mealName ? `Meal type: ${mealName}\n\n${idea}` : idea;
      if (submitBtn) submitBtn.disabled = true;
      spinner?.classList.remove('hidden');
      try {
        const res = await fetch('/api/request-booking', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            customer_name: v('customer_name'), customer_email: v('customer_email'), customer_phone: v('customer_phone'),
            num_guests: v('num_guests'), start_date: v('start_date'), end_date: v('end_date'), city: v('city'), event_address: v('event_address'),
            event_details: details, product: 'custom', marketing_consent: true,
            company_website: (document.querySelector('[name="company_website"]') as HTMLInputElement | null)?.value || '',
          }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) { showErr(data?.error || 'Could not send, please try again.'); if (submitBtn) submitBtn.disabled = false; spinner?.classList.add('hidden'); return; }
        showSuccess();
      } catch { showErr('Network error, please try again.'); if (submitBtn) submitBtn.disabled = false; spinner?.classList.add('hidden'); }
    });
  })();

  // ===== DISH PRE-FILL (from /menu "La Carta") =====
  // Selected dish ids travel via sessionStorage (primary) or ?dishes= (share
  // links / storage-unavailable fallback). Resolve ids -> names and prepend a
  // "Dishes I'd love:" line to the idea textarea, idempotently.
  (() => {
    const PREFIX_RE = /^Dishes I'd love:[^\n]*\n*/;

    function selectedIds(): string[] {
      try {
        const raw = sessionStorage.getItem('selectedDishes');
        if (raw) {
          const arr = JSON.parse(raw);
          if (Array.isArray(arr) && arr.length) return arr;
        }
      } catch { /* ignore */ }
      const fromUrl = new URLSearchParams(location.search).get('dishes');
      return fromUrl ? fromUrl.split(',').filter(Boolean) : [];
    }

    async function apply() {
      const ta = document.getElementById('event_details') as HTMLTextAreaElement | null;
      if (!ta || ta.disabled) return;
      const ids = selectedIds();
      if (!ids.length) return;
      const { DISHES } = await import('../lib/menu');
      const names = ids
        .map((id) => DISHES.find((d) => d.id === id)?.name)
        .filter((n): n is string => !!n);
      if (!names.length) return;
      const rest = ta.value.replace(PREFIX_RE, '');
      ta.value = `Dishes I'd love: ${names.join(', ')}\n\n${rest}`;
    }

    apply();
    // bfcache: coming back from /menu with a changed selection updates the line.
    window.addEventListener('pageshow', (e) => { if ((e as PageTransitionEvent).persisted) apply(); });
  })();

</script>
