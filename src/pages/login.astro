---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="Login - Private Chef Service" bodyClass="bg-gray-50 text-gray-900">
  <Header transparent={false} />

  <div class="min-h-[100dvh] pt-24 pb-16 px-4 sm:px-6 lg:px-8 flex items-center justify-center">
    <div class="w-full max-w-md">
      <div class="bg-white/90 backdrop-blur-sm shadow-xl rounded-2xl p-6 sm:p-8 border border-gray-100 animate-fade-in">
        <div class="mb-6 text-center">
          <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-gray-900">Sign in to your account</h1>
          <p class="mt-2 text-sm text-gray-500">Manage your Private Chef bookings</p>
        </div>

        <form class="space-y-4" id="login-form">
          <div class="space-y-2">
            <label for="email" class="block text-xs font-semibold text-gray-700 tracking-wide">Email</label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="5" width="18" height="14" rx="2" ry="2" />
                  <polyline points="3 7 12 13 21 7" />
                </svg>
              </span>
              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                required
                class="block w-full rounded-lg border border-gray-300 bg-white pl-10 pr-3 py-3 text-base sm:text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-black focus:border-black transition-all"
                placeholder="you@example.com"
              />
            </div>
          </div>

          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <label for="password" class="block text-xs font-semibold text-gray-700 tracking-wide">Password</label>
              <a href="/forgot-password" class="text-xs font-medium text-gray-500 hover:text-gray-900 transition-colors">Forgot password?</a>
            </div>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="10" rx="2" ry="2" />
                  <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
              </span>
              <input
                id="password"
                name="password"
                type="password"
                autocomplete="current-password"
                required
                minlength="6"
                class="block w-full rounded-lg border border-gray-300 bg-white pl-10 pr-10 py-3 text-base sm:text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-black focus:border-black transition-all"
                placeholder="Enter your password"
              />
            </div>
          </div>

          <div class="flex items-center justify-between text-xs text-gray-600">
            <label class="inline-flex items-center gap-2 cursor-pointer select-none">
              <input id="remember-me" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-black focus:ring-black" />
              <span class="font-medium">Remember me</span>
            </label>
          </div>

          <button
            id="login-submit"
            type="submit"
            class="w-full mt-2 inline-flex items-center justify-center gap-2 rounded-xl bg-black text-white py-3 text-sm font-semibold tracking-wide shadow-lg shadow-black/10 hover:bg-gray-900 active:scale-[0.99] transition-all duration-200"
          >
            <span>Sign in</span>
          </button>

          <p id="login-error" class="mt-2 text-sm text-red-500 hidden"></p>
        </form>

        <div class="mt-6 flex items-center gap-3">
          <span class="h-px flex-1 bg-gray-200"></span>
          <span class="text-xs font-medium text-gray-400">Or continue with</span>
          <span class="h-px flex-1 bg-gray-200"></span>
        </div>

        <button
          id="google-login"
          type="button"
          class="mt-4 w-full inline-flex items-center justify-center gap-3 rounded-xl border border-gray-300 bg-white py-3 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-50 active:scale-[0.99] transition-all duration-200"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23z" />
            <path fill="#FBBC05" d="M5.84 14.1a6.6 6.6 0 0 1 0-4.2V7.06H2.18a11 11 0 0 0 0 9.88l3.66-2.84z" />
            <path fill="#EA4335" d="M12 4.74c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 1.19 14.97 0 12 0A11 11 0 0 0 2.18 7.06l3.66 2.84C6.71 7.3 9.14 4.74 12 4.74z" />
          </svg>
          <span>Continue with Google</span>
        </button>

        <p class="mt-6 text-center text-xs text-gray-500">
          Don't have an account?
          <a href="/signup" class="font-semibold text-gray-900 hover:underline">Sign up</a>
        </p>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase, writeSessionCookies, clearSessionCookies } from '../lib/supabase';
  const googleBtn = document.getElementById('google-login');
  const loginForm = document.getElementById('login-form') as HTMLFormElement;
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const errorBox = document.getElementById('login-error') as HTMLParagraphElement | null;
  const submitBtn = document.getElementById('login-submit') as HTMLButtonElement | null;

  const urlParams = new URLSearchParams(window.location.search);
  const returnToParam = urlParams.get('returnTo');

  function validateEmail(email: string) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  async function handlePostAuthRedirect() {
    let { data: { session } } = await supabase.auth.getSession();
    if (!session) return; // not logged in → stay on the login form

    // Ensure the token handed to the server is currently valid. If it is
    // missing/expiring, refresh it. If the refresh FAILS (the refresh token was
    // rotated/revoked), the localStorage session is dead: purge it and stay here
    // instead of writing a dead cookie and redirecting — that dead-cookie rewrite
    // was the engine of the /dashboard <-> /login infinite loop.
    const expiresSoon = !session.expires_at || session.expires_at * 1000 < Date.now() + 120000;
    if (expiresSoon) {
      const r = await supabase.auth.refreshSession();
      if (r.data.session) {
        session = r.data.session;
      } else {
        await supabase.auth.signOut({ scope: 'local' });
        clearSessionCookies();
        return;
      }
    }
    const user = session.user;
    if (!user) return;

    // Mirror the (validated) session into the server-readable cookies.
    writeSessionCookies(session);

    // The owner's home is the /owner console — skip customer onboarding.
    if (user.email?.toLowerCase() === 'ninaglia089@gmail.com') {
      window.location.href = '/owner';
      return;
    }

    const { data: profile } = await supabase
      .from('profiles')
      .select('full_name, phone, city')
      .eq('id', user.id)
      .maybeSingle();

    // "Onboarded" = has the basic contact details. Do NOT depend on an
    // onboarding_completed column (it may be absent on the live DB, which made
    // this always-false and caused the infinite /complete-profile loop).
    const onboardingComplete = !!(profile && profile.full_name && profile.phone && profile.city);

    // Sanitize returnTo so it can never point back at /login or /complete-profile
    // (that recursion was the other half of the loop). Same-site paths only.
    let target = returnToParam || '/dashboard';
    if (!target.startsWith('/') || target.startsWith('//') || target.startsWith('/login') || target.startsWith('/complete-profile')) {
      target = '/dashboard';
    }

    if (!onboardingComplete) {
      window.location.href = `/complete-profile?returnTo=${encodeURIComponent(target)}`;
      return;
    }

    window.location.href = target;
  }

  googleBtn?.addEventListener('click', async () => {
    if (googleBtn) {
      (googleBtn as HTMLButtonElement).disabled = true;
      googleBtn.classList.add('opacity-70', 'cursor-not-allowed');
    }
    if (errorBox) {
      errorBox.classList.add('hidden');
      errorBox.textContent = '';
    }
    const params = new URLSearchParams(window.location.search);
    const rt = params.get('returnTo');
    // Always return to /auth/callback so the PKCE ?code= is exchanged for a
    // session there. Returning to /login (old behavior) never finalized the
    // code and hung. Pass returnTo through so the gate can honor it.
    const redirectUrl = rt
      ? `${window.location.origin}/auth/callback?returnTo=${encodeURIComponent(rt)}`
      : `${window.location.origin}/auth/callback`;
    const { error } = await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: {
        redirectTo: redirectUrl,
      },
    });
    // On success the browser navigates to Google, so code below only runs on error.
    if (error) {
      if (googleBtn) {
        (googleBtn as HTMLButtonElement).disabled = false;
        googleBtn.classList.remove('opacity-70', 'cursor-not-allowed');
      }
      if (errorBox) {
        errorBox.textContent = error.message;
        errorBox.classList.remove('hidden');
      }
    }
  });

  loginForm?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (errorBox) {
      errorBox.classList.add('hidden');
      errorBox.textContent = '';
    }

    emailInput.classList.remove('border-red-500', 'focus:ring-red-500', 'focus:border-red-500');
    passwordInput.classList.remove('border-red-500', 'focus:ring-red-500', 'focus:border-red-500');

    let hasError = false;

    if (!validateEmail(emailInput.value.trim())) {
      hasError = true;
      emailInput.classList.add('border-red-500', 'focus:ring-red-500', 'focus:border-red-500');
      if (errorBox && !errorBox.textContent) {
        errorBox.textContent = 'Please enter a valid email address.';
      }
    }

    if (passwordInput.value.length < 6) {
      hasError = true;
      passwordInput.classList.add('border-red-500', 'focus:ring-red-500', 'focus:border-red-500');
      if (errorBox && !errorBox.textContent) {
        errorBox.textContent = 'Password must be at least 6 characters long.';
      }
    }

    if (hasError) {
      if (errorBox) errorBox.classList.remove('hidden');
      return;
    }

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
    }

    const { error } = await supabase.auth.signInWithPassword({
      email: emailInput.value.trim(),
      password: passwordInput.value,
    });

    if (submitBtn) {
      submitBtn.disabled = false;
      submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
    }

    if (error) {
      if (errorBox) {
        const emailVal = emailInput.value.trim();
        const code = (error as any).code;
        if (code === 'email_not_confirmed' || /email not confirmed/i.test(error.message)) {
          // Unconfirmed account: don't dump the raw error — explain + offer resend.
          errorBox.innerHTML =
            'You need to confirm your email first — we sent you a link when you signed up. ' +
            '<a href="#" id="resend-confirm" class="font-semibold underline">Resend the confirmation email</a>.';
          errorBox.classList.remove('hidden');
          document.getElementById('resend-confirm')?.addEventListener('click', async (ev) => {
            ev.preventDefault();
            errorBox.textContent = 'Sending…';
            const { error: resendErr } = await supabase.auth.resend({ type: 'signup', email: emailVal });
            errorBox.textContent = resendErr
              ? `Could not resend right now: ${resendErr.message}`
              : 'Confirmation email sent — check your inbox (and spam).';
            errorBox.classList.remove('hidden');
          });
        } else if (/invalid login credentials/i.test(error.message)) {
          errorBox.textContent = 'Incorrect email or password.';
          errorBox.classList.remove('hidden');
        } else {
          errorBox.textContent = error.message;
          errorBox.classList.remove('hidden');
        }
      }
    } else {
      handlePostAuthRedirect();
    }
  });

  // If already logged in (e.g. after Google redirect), apply redirect logic
  handlePostAuthRedirect();

</script>
