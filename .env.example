# =============================================================================
# Private Chef Service — environment variables (TEMPLATE — no real secrets here)
# =============================================================================
# Copy to `.env` for local dev and fill with TEST values. In production these
# live in Vercel → Project "private-chef-service" → Settings → Environment
# Variables. Every var below must exist in BOTH "Production" AND "Preview"
# (and ideally "Development") so server endpoints don't 500 on preview deploys.
#
# Read by the app via import.meta.env.* — names must match EXACTLY.
# Vars prefixed PUBLIC_ are exposed to the browser; all others are server-only.
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# Project "private chef at home" (ref zyptbqfldwvbxntwrfqq).
# Dashboard → Project Settings → API.
PUBLIC_SUPABASE_URL=https://zyptbqfldwvbxntwrfqq.supabase.co
PUBLIC_SUPABASE_ANON_KEY=          # "anon" / publishable key (safe in browser)
SUPABASE_SERVICE_ROLE_KEY=        # service_role key — SERVER ONLY, never expose

# --- Stripe ------------------------------------------------------------------
# Dashboard → Developers → API keys (use LIVE keys in production).
STRIPE_SECRET_KEY=               # sk_live_... in prod, sk_test_... locally
STRIPE_WEBHOOK_SECRET=           # whsec_... from the webhook endpoint (per-endpoint, per-mode)

# --- Resend (transactional email) --------------------------------------------
# resend.com → API Keys. Sending domain must be verified (see GO-LIVE-SETUP.md).
RESEND_API_KEY=                  # re_...
# From-addresses. MUST be "Display Name <user@verified-domain>" or Resend rejects.
# Defaults in code (if unset): info@ninos-privatechefs.com / sistema@ninos-privatechefs.com
EMAIL_FROM=Nino's Private Chef <hello@ninos-privatechefs.com>   # customer-facing
EMAIL_SYSTEM=Private Chef System <system@ninos-privatechefs.com> # internal notifications

# --- Welcome-email webhook ---------------------------------------------------
# Shared secret guarding POST /api/welcome (Supabase auth → send welcome email).
# Sent by the caller as header `x-webhook-secret`. Any long random string.
WELCOME_WEBHOOK_SECRET=

# --- Twilio (SMS + WhatsApp notifications) — OPTIONAL ------------------------
# If unset, SMS/WhatsApp are silently skipped (the site still works).
TWILIO_ACCOUNT_SID=              # AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=              # SMS sender, E.164 e.g. +1...
TWILIO_WHATSAPP_NUMBER=          # e.g. whatsapp:+14155238886 (Twilio sandbox by default)
ORGANIZER_PHONE=                 # owner's WhatsApp for new-booking alerts, e.g. +39...
